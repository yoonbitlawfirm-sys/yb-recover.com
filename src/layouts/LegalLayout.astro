---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import { getCurrentSite } from '../config/sites.js';
import { getThemeStyle } from '../lib/theme.js';

const {
  title,
  description,
  eyebrow = 'LEGAL INFORMATION',
  updated = '2026년 7월 11일'
} = Astro.props;

const site = getCurrentSite(Astro.url.host);
const canonical = Astro.url.toString();
const fullTitle = `${title} | ${site.siteName}`;
const themeStyle = getThemeStyle(site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="NaverBot" content="index, follow" />
    <meta name="Yeti" content="index, follow" />
    <meta name="author" content={site.operatorName} />
    <meta name="theme-color" content={site.colors?.bg || '#02050b'} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={site.favicon || '/images/favicon.png?v=20260711'} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
  </head>

  <body class={`yb-theme yb-theme--${site.theme}`} style={themeStyle}>
    <main class="yb-legal-page">
      <div class="yb-legal-page__background" aria-hidden="true"></div>
      <div class="yb-legal-page__inner">
        <a class="yb-legal-page__back" href="/">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6"></path></svg>
          발사대로 돌아가기
        </a>

        <header class="yb-legal-page__header">
          <p>{eyebrow}</p>
          <h1>{title}</h1>
          <span>{description}</span>
          <small>시행·최종 수정일: {updated}</small>
        </header>

        <article class="yb-legal-document">
          <slot />
        </article>
      </div>
    </main>

    <Footer site={site} compact />

    <style>
      .yb-legal-page {
        position: relative;
        min-height: 72vh;
        isolation: isolate;
        overflow: hidden;
        padding: 56px 22px 100px;
        background:
          radial-gradient(circle at 82% 10%, var(--yb-accent-soft), transparent 26%),
          linear-gradient(145deg, var(--yb-bg-deep), var(--yb-bg-mid) 58%, var(--yb-bg-deep));
      }

      .yb-legal-page__background {
        position: absolute;
        inset: 0;
        z-index: -1;
        background:
          linear-gradient(rgba(255, 255, 255, 0.014) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
        background-size: 82px 82px;
        opacity: 0.34;
      }

      .yb-legal-page__inner {
        width: min(960px, 100%);
        margin: 0 auto;
      }

      .yb-legal-page__back {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0 14px;
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 999px;
        background: rgba(2, 5, 11, 0.62);
        color: rgba(255, 255, 255, 0.72);
        font-size: 13px;
      }

      .yb-legal-page__back svg {
        width: 16px;
        height: 16px;
      }

      .yb-legal-page__back:hover,
      .yb-legal-page__back:focus-visible {
        color: #fff;
        border-color: var(--yb-accent-2);
      }

      .yb-legal-page__header {
        padding: 76px 0 42px;
      }

      .yb-legal-page__header > p {
        margin: 0 0 12px;
        color: var(--yb-accent-2);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: 0.18em;
      }

      .yb-legal-page__header h1 {
        margin: 0;
        color: #fff;
        font-size: clamp(38px, 6vw, 64px);
        font-weight: 650;
        line-height: 1.16;
        letter-spacing: -0.065em;
      }

      .yb-legal-page__header > span {
        display: block;
        max-width: 760px;
        margin-top: 18px;
        color: var(--yb-muted);
        font-size: 16px;
        line-height: 1.8;
        letter-spacing: -0.03em;
      }

      .yb-legal-page__header > small {
        display: block;
        margin-top: 14px;
        color: rgba(255, 255, 255, 0.42);
        font-size: 12px;
      }

      .yb-legal-document {
        display: grid;
        gap: 15px;
        padding: clamp(24px, 4vw, 42px);
        border: 1px solid var(--yb-line);
        border-radius: 16px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025)),
          rgba(2, 5, 11, 0.68);
        box-shadow: 0 28px 80px rgba(0, 0, 0, 0.32);
      }

      :global(.yb-legal-document section) {
        padding: 26px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      :global(.yb-legal-document section:first-child) {
        padding-top: 0;
      }

      :global(.yb-legal-document section:last-child) {
        padding-bottom: 0;
        border-bottom: 0;
      }

      :global(.yb-legal-document h2) {
        margin: 0 0 14px;
        color: #fff;
        font-size: 21px;
        font-weight: 760;
        line-height: 1.45;
        letter-spacing: -0.045em;
      }

      :global(.yb-legal-document h3) {
        margin: 20px 0 9px;
        color: rgba(255, 255, 255, 0.88);
        font-size: 16px;
        font-weight: 720;
        line-height: 1.5;
        letter-spacing: -0.035em;
      }

      :global(.yb-legal-document p),
      :global(.yb-legal-document li) {
        color: var(--yb-muted);
        font-size: 14px;
        line-height: 1.82;
        letter-spacing: -0.025em;
      }

      :global(.yb-legal-document p) {
        margin: 7px 0 0;
      }

      :global(.yb-legal-document ul),
      :global(.yb-legal-document ol) {
        display: grid;
        gap: 7px;
        margin: 10px 0 0;
        padding-left: 22px;
      }

      :global(.yb-legal-document strong) {
        color: rgba(255, 255, 255, 0.90);
      }

      :global(.yb-legal-document a) {
        color: var(--yb-accent-2);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      :global(.yb-legal-document table) {
        width: 100%;
        margin-top: 13px;
        border-collapse: collapse;
        table-layout: fixed;
      }

      :global(.yb-legal-document th),
      :global(.yb-legal-document td) {
        padding: 12px 13px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        color: var(--yb-muted);
        font-size: 13px;
        line-height: 1.7;
        text-align: left;
        vertical-align: top;
        overflow-wrap: anywhere;
      }

      :global(.yb-legal-document th) {
        background: var(--yb-secondary-soft);
        color: rgba(255, 255, 255, 0.88);
        font-weight: 720;
      }

      :global(.yb-legal-document .yb-legal-callout) {
        margin-top: 14px;
        padding: 16px 17px;
        border: 1px solid var(--yb-line);
        border-radius: 10px;
        background: var(--yb-secondary-soft);
      }

      @media (max-width: 640px) {
        .yb-legal-page {
          padding: 28px 16px 74px;
        }

        .yb-legal-page__header {
          padding: 58px 0 32px;
        }

        .yb-legal-page__header h1 {
          font-size: clamp(34px, 10vw, 46px);
        }

        .yb-legal-document {
          padding: 22px 18px;
          border-radius: 13px;
        }

        :global(.yb-legal-document section) {
          padding: 22px 0;
        }

        :global(.yb-legal-document h2) {
          font-size: 19px;
        }

        :global(.yb-legal-document table),
        :global(.yb-legal-document tbody),
        :global(.yb-legal-document tr),
        :global(.yb-legal-document th),
        :global(.yb-legal-document td) {
          display: block;
          width: 100%;
        }

        :global(.yb-legal-document tr) {
          margin-top: 10px;
        }

        :global(.yb-legal-document th) {
          border-bottom: 0;
        }
      }
    </style>
  </body>
</html>
