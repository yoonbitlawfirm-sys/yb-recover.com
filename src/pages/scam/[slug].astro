---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import CasePage from '../../components/CasePage.astro';
import { getCurrentSite } from '../../config/sites.js';
import { getCaseBySlug } from '../../lib/sheet.js';
import { getStatus } from '../../lib/utils.js';
import { buildCaseSeo, caseJsonLdGraph } from '../../lib/seo.js';

export const prerender = false;

const site = getCurrentSite(Astro.url.host);
const { slug } = Astro.params;
const row = await getCaseBySlug(slug, site);

if (!row) {
  return new Response('페이지를 찾을 수 없습니다.', {
    status: 404,
    headers: { 'content-type': 'text/plain; charset=utf-8' }
  });
}

const status = getStatus(row);

if (status === 'deleted') {
  return new Response('삭제된 페이지입니다.', {
    status: 410,
    headers: {
      'content-type': 'text/plain; charset=utf-8',
      'x-robots-tag': 'noindex'
    }
  });
}

if (status === 'disabled' || status === 'draft') {
  return new Response('비공개 페이지입니다.', {
    status: 404,
    headers: {
      'content-type': 'text/plain; charset=utf-8',
      'x-robots-tag': 'noindex'
    }
  });
}

if (status === 'redirect' && row.redirectTo) {
  return Astro.redirect(row.redirectTo, 302);
}

const seo = buildCaseSeo(row, site, Astro.url);
const robots = status === 'noindex' ? 'noindex, nofollow' : 'index, follow';

const jsonLd = caseJsonLdGraph(row, site, Astro.url, seo);

const ogImage = `${Astro.url.origin}/images/yoonbit-og.png`;
const favicon = '/images/favicon.png';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={robots === 'index, follow' ? 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' : robots} />
    <meta name="keywords" content={seo.keywords.join(', ')} />
    <meta name="author" content={site.siteName} />
    <meta name="content-language" content="ko-KR" />
    <meta name="subject" content={`${seo.name} 사칭 사기 피해 대응`} />
    <meta name="theme-color" content="#02050b" />

    <meta name="NaverBot" content="index, follow" />
    <meta name="Yeti" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <link rel="canonical" href={seo.canonical} />
    <link rel="alternate" hreflang="ko-KR" href={seo.canonical} />
    <link rel="alternate" hreflang="x-default" href={seo.canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${site.siteName} RSS`} href={`${Astro.url.origin}/rss.xml`} />
    <link rel="sitemap" type="application/xml" href={`${Astro.url.origin}/sitemap.xml`} />

    <link rel="icon" type="image/png" href={favicon} />
    <link rel="shortcut icon" type="image/png" href={favicon} />
    <link rel="apple-touch-icon" href={favicon} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.siteName} />
    <meta property="og:locale" content="ko_KR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${seo.name} 사칭 사기 피해 대응`} />

    <meta property="article:published_time" content={`${seo.publishedAt}T09:00:00+09:00`} />
    <meta property="article:modified_time" content={`${seo.updatedAt}T09:00:00+09:00`} />
    <meta property="article:section" content={seo.caseType} />
    <meta property="article:author" content={site.brandName} />
    {seo.keywords.slice(0, 6).map((keyword) => <meta property="article:tag" content={keyword} />)}
    <link rel="image_src" href={ogImage} />
    <meta itemprop="image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <div class="yb-page">
      <Header site={site} />

      <main>
        <CasePage site={site} row={row} />
      </main>

      <Footer site={site} />
      <FloatingCTA site={site} label={`${seo.name} 피해 상담`} />
    </div>

    <script is:inline>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.12,
          rootMargin: '0px 0px -8% 0px'
        }
      );

      document.querySelectorAll('.yb-reveal').forEach((el) => io.observe(el));

      document.querySelectorAll('.yb-faq-q').forEach((q) => {
        q.addEventListener('click', () => {
          q.closest('.yb-faq-item').classList.toggle('open');
        });

        q.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            q.click();
          }
        });
      });
    </script>
      {site.siteKey === 'yb-recover' && (
      <>
        <script is:inline type="text/javascript">var hpt_info={'_account':'UHPT-300506','_server':'a300'};</script>
        <script is:inline src="//cdn.smlog.co.kr/core/smart_renew.js" charset="utf-8"></script>
        <noscript><img src="//a300.smlog.co.kr/smart_bda?_account=300506" style="display:none;width:0;height:0;" border="0" alt="" /></noscript>
      </>
    )}
  </body>
</html>