---
import '../../styles/global.css';

import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';

import { getCurrentSite } from '../../config/sites.js';

export const prerender = false;

/* =========================================================
   1. 현재 접속 도메인 확인
========================================================= */

const hostname = String(Astro.url.hostname || '')
  .trim()
  .toLowerCase()
  .replace(/^www\./, '');

const slug = String(Astro.params.slug || '')
  .trim()
  .toLowerCase();

/* =========================================================
   2. 실제 도메인 → 구글시트 domain 값 매핑
========================================================= */

const DOMAIN_KEY_MAP = {
  'yb-recover.com': 'yb-recover',

  'yb-response.com': 'yb-response',
  'yb-alert.com': 'yb-alert',
  'yb-check.com': 'yb-check',
  'yb-case.com': 'yb-case',
  'yb-safe.com': 'yb-safe',
  'yb-help.com': 'yb-help',
  'yb-watch.co.kr': 'yb-watch',
};

const site = getCurrentSite(Astro.url.host);

const domainKey =
  DOMAIN_KEY_MAP[hostname] ||
  String(site?.siteKey || '').trim().toLowerCase();

/* =========================================================
   3. yb-recover.com은 메인 발사대 전용
   /scam 주소로 들어오면 메인으로 이동
========================================================= */

if (domainKey === 'yb-recover') {
  return Astro.redirect('/', 302);
}

/* =========================================================
   4. 허용되지 않은 도메인 차단
========================================================= */

const WEB_DISTRIBUTION_DOMAINS = [
  'yb-response',
  'yb-alert',
  'yb-check',
  'yb-case',
  'yb-safe',
  'yb-help',
  'yb-watch',
];

if (!WEB_DISTRIBUTION_DOMAINS.includes(domainKey)) {
  Astro.response.status = 404;
}

/* =========================================================
   5. 구글시트 Apps Script API 주소

   Vercel 환경변수:
   SHEET_API_URL=https://script.google.com/macros/s/배포ID/exec
========================================================= */

const SHEET_API_URL =
  import.meta.env.SHEET_JSON_URL ||
  '';

let pageData = null;
let loadError = '';

/* =========================================================
   6. 시트 데이터 불러오기
========================================================= */

if (!SHEET_API_URL) {
  loadError = 'SHEET_API_URL 환경변수가 설정되지 않았습니다.';
} else if (!slug) {
  loadError = '페이지 주소가 올바르지 않습니다.';
} else if (WEB_DISTRIBUTION_DOMAINS.includes(domainKey)) {
  try {
    const separator = SHEET_API_URL.includes('?') ? '&' : '?';

    const response = await fetch(
      `${SHEET_API_URL}${separator}domain=${encodeURIComponent(domainKey)}&slug=${encodeURIComponent(slug)}&t=${Date.now()}`,
      {
        headers: {
          Accept: 'application/json',
        },
      }
    );

    if (!response.ok) {
      throw new Error(
        `시트 API 응답 오류: ${response.status}`
      );
    }

    const result = await response.json();

    const rows = Array.isArray(result)
      ? result
      : Array.isArray(result?.data)
        ? result.data
        : [];

    pageData =
      rows.find((row) => {
        const rowDomain = String(row?.domain || '')
          .trim()
          .toLowerCase()
          .replace(/^www\./, '')
          .replace(/^https?:\/\//, '')
          .replace(/\/.*$/, '')
          .replace(/\.co\.kr$/, '')
          .replace(/\.com$/, '')
          .replace(/\.net$/, '')
          .replace(/\.kr$/, '');

        const rowSlug = String(row?.slug || '')
          .trim()
          .toLowerCase();

        const rowStatus = String(row?.status || '')
          .trim()
          .toLowerCase();

        return (
          rowDomain === domainKey &&
          rowSlug === slug &&
          rowStatus === 'published'
        );
      }) || null;

    if (!pageData) {
      loadError = '등록된 웹배포 페이지를 찾을 수 없습니다.';
    }
  } catch (error) {
    console.error('[SCAM PAGE FETCH ERROR]', error);

    loadError =
      error instanceof Error
        ? error.message
        : '웹배포 데이터를 불러오지 못했습니다.';
  }
}

/* =========================================================
   7. 데이터가 없으면 실제 404 응답
========================================================= */

if (!pageData) {
  Astro.response.status = 404;
}

/* =========================================================
   8. SEO 데이터
========================================================= */

const siteName =
  site?.siteName ||
  '법무법인 윤빛 금융사기 피해회복센터';

const pageTitle =
  pageData?.seoTitle ||
  pageData?.headline ||
  `${siteName} | 금융사기 피해 대응`;

const pageDescription =
  pageData?.seoDescription ||
  pageData?.subHeadline ||
  '금융사기 피해 사실관계와 대응 가능성을 확인합니다.';

const canonicalUrl = new URL(
  `/scam/${encodeURIComponent(slug)}`,
  Astro.url.origin
).toString();

const faviconUrl =
  '/images/favicon.png?v=20260710';

const ogImageUrl = new URL(
  '/images/yoonbit-og.png?v=20260710',
  Astro.url.origin
).toString();

const publishedAt =
  pageData?.publishedAt || '';

const updatedAt =
  pageData?.updatedAt ||
  pageData?.publishedAt ||
  '';

const riskItems = [
  pageData?.risk1,
  pageData?.risk2,
  pageData?.risk3,
].filter(Boolean);

const triggerItems = [
  pageData?.trigger1,
  pageData?.trigger2,
  pageData?.trigger3,
].filter(Boolean);

const reviewItems = [
  pageData?.review1,
  pageData?.review2,
  pageData?.review3,
].filter(Boolean);

const faqItems = [
  {
    question: pageData?.faq1Q,
    answer: pageData?.faq1A,
  },
  {
    question: pageData?.faq2Q,
    answer: pageData?.faq2A,
  },
  {
    question: pageData?.faq3Q,
    answer: pageData?.faq3A,
  },
].filter(
  (item) => item.question && item.answer
);

const jsonLd = pageData
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: pageTitle,
      description: pageDescription,
      mainEntityOfPage: canonicalUrl,
      datePublished: publishedAt || undefined,
      dateModified: updatedAt || undefined,
      publisher: {
        '@type': 'Organization',
        name: siteName,
        url: Astro.url.origin,
      },
      image: [ogImageUrl],
    }
  : null;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{pageTitle}</title>

    <meta
      name="description"
      content={pageDescription}
    />

    <meta
      name="robots"
      content={pageData ? 'index, follow, max-image-preview:large, max-snippet:-1' : 'noindex, nofollow'}
    />

    <meta
      name="googlebot"
      content={pageData ? 'index, follow' : 'noindex, nofollow'}
    />

    <meta
      name="NaverBot"
      content={pageData ? 'index, follow' : 'noindex, nofollow'}
    />

    <meta
      name="Yeti"
      content={pageData ? 'index, follow' : 'noindex, nofollow'}
    />

    <meta
      name="author"
      content={site?.operatorName || siteName}
    />

    <meta
      name="theme-color"
      content="#02050b"
    />

    <link
      rel="canonical"
      href={canonicalUrl}
    />

    <link
      rel="alternate"
      hreflang="ko-KR"
      href={canonicalUrl}
    />

    <link
      rel="alternate"
      hreflang="x-default"
      href={canonicalUrl}
    />

    <link
      rel="icon"
      type="image/png"
      href={faviconUrl}
    />

    <link
      rel="shortcut icon"
      type="image/png"
      href={faviconUrl}
    />

    <link
      rel="apple-touch-icon"
      href={faviconUrl}
    />

    <meta
      property="og:type"
      content="article"
    />

    <meta
      property="og:locale"
      content="ko_KR"
    />

    <meta
      property="og:site_name"
      content={siteName}
    />

    <meta
      property="og:title"
      content={pageTitle}
    />

    <meta
      property="og:description"
      content={pageDescription}
    />

    <meta
      property="og:url"
      content={canonicalUrl}
    />

    <meta
      property="og:image"
      content={ogImageUrl}
    />

    <meta
      property="og:image:secure_url"
      content={ogImageUrl}
    />

    <meta
      property="og:image:type"
      content="image/png"
    />

    <meta
      property="og:image:width"
      content="1200"
    />

    <meta
      property="og:image:height"
      content="630"
    />

    <meta
      property="og:image:alt"
      content={pageTitle}
    />

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:title"
      content={pageTitle}
    />

    <meta
      name="twitter:description"
      content={pageDescription}
    />

    <meta
      name="twitter:image"
      content={ogImageUrl}
    />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>

  <body>
    <div class="yb-page">
      <Header site={site} />

      {
        pageData ? (
          <main class="distribution-page">

            <section class="distribution-hero">
              <div class="distribution-container">

                {pageData.heroBadge && (
                  <div class="distribution-badge">
                    {pageData.heroBadge}
                  </div>
                )}

                <p class="distribution-domain">
                  {domainKey}
                </p>

                <h1>
                  {pageData.headline || pageTitle}
                </h1>

                {pageData.subHeadline && (
                  <p class="distribution-subheadline">
                    {pageData.subHeadline}
                  </p>
                )}

                {pageData.noticeText && (
                  <div class="distribution-notice">
                    {pageData.noticeText}
                  </div>
                )}

                {(publishedAt || updatedAt) && (
                  <div class="distribution-date">
                    {publishedAt && (
                      <span>
                        게시일 {publishedAt}
                      </span>
                    )}

                    {updatedAt && (
                      <span>
                        최종 수정 {updatedAt}
                      </span>
                    )}
                  </div>
                )}
              </div>
            </section>

            {riskItems.length > 0 && (
              <section class="distribution-section">
                <div class="distribution-container">
                  <div class="section-heading">
                    <span>RISK SIGNAL</span>

                    <h2>
                      현재 상황에서 확인해야 할 위험 신호
                    </h2>
                  </div>

                  <div class="distribution-grid">
                    {riskItems.map((item, index) => (
                      <article class="distribution-card">
                        <strong>
                          {String(index + 1).padStart(2, '0')}
                        </strong>

                        <p>{item}</p>
                      </article>
                    ))}
                  </div>
                </div>
              </section>
            )}

            {triggerItems.length > 0 && (
              <section class="distribution-section distribution-dark">
                <div class="distribution-container">
                  <div class="section-heading">
                    <span>IMMEDIATE CHECK</span>

                    <h2>
                      아래 정황이 있다면 즉시 확인이 필요합니다
                    </h2>
                  </div>

                  <div class="trigger-list">
                    {triggerItems.map((item) => (
                      <div class="trigger-item">
                        <span>!</span>
                        <p>{item}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </section>
            )}

            {(pageData.factTitle || pageData.factBody) && (
              <section class="distribution-section">
                <div class="distribution-container">
                  <article class="fact-box">
                    <span>FACT CHECK</span>

                    {pageData.factTitle && (
                      <h2>{pageData.factTitle}</h2>
                    )}

                    {pageData.factBody && (
                      <p>{pageData.factBody}</p>
                    )}
                  </article>
                </div>
              </section>
            )}

            {pageData.processTitle && (
              <section class="distribution-section distribution-dark">
                <div class="distribution-container">
                  <div class="section-heading">
                    <span>RESPONSE PROCESS</span>

                    <h2>{pageData.processTitle}</h2>
                  </div>

                  <div class="process-grid">
                    <article>
                      <strong>01</strong>
                      <h3>피해 자료 확인</h3>
                      <p>
                        입금 내역, 대화 자료, 사이트 정보와 피해 경위를 확인합니다.
                      </p>
                    </article>

                    <article>
                      <strong>02</strong>
                      <h3>대응 가능성 검토</h3>
                      <p>
                        자금 흐름과 상대방의 요구 내용을 기준으로 대응 방향을 검토합니다.
                      </p>
                    </article>

                    <article>
                      <strong>03</strong>
                      <h3>후속 절차 안내</h3>
                      <p>
                        확인된 사실관계에 따라 필요한 법적 절차와 대응 순서를 안내합니다.
                      </p>
                    </article>
                  </div>
                </div>
              </section>
            )}

            {reviewItems.length > 0 && (
              <section class="distribution-section">
                <div class="distribution-container">
                  <div class="section-heading">
                    <span>CASE REVIEW</span>

                    <h2>
                      피해 대응 사례
                    </h2>
                  </div>

                  <div class="review-grid">
                    {reviewItems.map((item) => (
                      <blockquote>
                        <p>{item}</p>
                      </blockquote>
                    ))}
                  </div>
                </div>
              </section>
            )}

            {faqItems.length > 0 && (
              <section class="distribution-section distribution-dark">
                <div class="distribution-container">
                  <div class="section-heading">
                    <span>FAQ</span>

                    <h2>
                      자주 묻는 질문
                    </h2>
                  </div>

                  <div class="faq-list">
                    {faqItems.map((item) => (
                      <details>
                        <summary>
                          {item.question}
                        </summary>

                        <p>{item.answer}</p>
                      </details>
                    ))}
                  </div>
                </div>
              </section>
            )}

            <section class="distribution-final">
              <div class="distribution-container">
                <span>
                  LAW FIRM YOONBIT
                </span>

                <h2>
                  피해 사실을 확인한 시점부터<br />
                  대응을 시작해야 합니다.
                </h2>

                <p>
                  접수 후 담당자가 피해 정황과 자료를 확인하여 연락드립니다.
                </p>

                <div class="final-actions">
                  <a href={`tel:${site?.tel || ''}`}>
                    전화 상담
                  </a>

                  {site?.kakao && (
                    <a
                      href={site.kakao}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      카카오 상담
                    </a>
                  )}
                </div>
              </div>
            </section>
          </main>
        ) : (
          <main class="distribution-error">
            <div>
              <span>404</span>

              <h1>
                페이지를 찾을 수 없습니다.
              </h1>

              <p>
                {loadError || '등록되지 않았거나 게시 상태가 아닌 페이지입니다.'}
              </p>
            </div>
          </main>
        )
      }

      <Footer site={site} />

      {
        pageData && (
          <FloatingCTA
            site={site}
            label={pageData?.headline || siteName}
          />
        )
      }
    </div>

    <style>
      .distribution-page {
        background:
          radial-gradient(
            circle at 50% 0%,
            rgba(41, 74, 130, 0.18),
            transparent 34%
          ),
          #03070d;
        color: #ffffff;
      }

      .distribution-container {
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
      }

      .distribution-hero {
        position: relative;
        overflow: hidden;
        padding: 150px 0 110px;
        text-align: center;
        background:
          linear-gradient(
            180deg,
            rgba(3, 7, 13, 0.72),
            #03070d
          ),
          radial-gradient(
            circle at 50% 20%,
            rgba(38, 72, 128, 0.26),
            transparent 45%
          );
      }

      .distribution-hero::before {
        position: absolute;
        inset: 0;
        content: '';
        pointer-events: none;
        background:
          linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.02),
            transparent
          );
      }

      .distribution-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
        padding: 0 16px;
        border: 1px solid rgba(184, 202, 231, 0.25);
        border-radius: 999px;
        color: #d7e1ef;
        background: rgba(255, 255, 255, 0.035);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.05em;
      }

      .distribution-domain {
        margin: 26px 0 14px;
        color: #7891b4;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .distribution-hero h1 {
        max-width: 900px;
        margin: 0 auto;
        font-size: clamp(34px, 5.2vw, 68px);
        font-weight: 700;
        line-height: 1.18;
        letter-spacing: -0.045em;
        word-break: keep-all;
      }

      .distribution-subheadline {
        max-width: 760px;
        margin: 26px auto 0;
        color: #b8c2d1;
        font-size: clamp(17px, 2vw, 21px);
        line-height: 1.8;
        word-break: keep-all;
      }

      .distribution-notice {
        max-width: 760px;
        margin: 34px auto 0;
        padding: 18px 22px;
        border: 1px solid rgba(167, 187, 218, 0.18);
        border-radius: 14px;
        color: #d6deea;
        background: rgba(255, 255, 255, 0.035);
        font-size: 15px;
        line-height: 1.75;
      }

      .distribution-date {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px 24px;
        margin-top: 24px;
        color: #6f7e93;
        font-size: 12px;
      }

      .distribution-section {
        padding: 105px 0;
      }

      .distribution-dark {
        border-top: 1px solid rgba(255, 255, 255, 0.055);
        border-bottom: 1px solid rgba(255, 255, 255, 0.055);
        background: #050a12;
      }

      .section-heading {
        max-width: 780px;
        margin: 0 auto 48px;
        text-align: center;
      }

      .section-heading span,
      .fact-box > span,
      .distribution-final > div > span {
        display: block;
        margin-bottom: 14px;
        color: #718eb8;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.16em;
      }

      .section-heading h2,
      .fact-box h2,
      .distribution-final h2 {
        margin: 0;
        font-size: clamp(28px, 4vw, 46px);
        font-weight: 700;
        line-height: 1.3;
        letter-spacing: -0.035em;
        word-break: keep-all;
      }

      .distribution-grid,
      .process-grid,
      .review-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .distribution-card,
      .process-grid article,
      .review-grid blockquote {
        margin: 0;
        padding: 32px;
        border: 1px solid rgba(255, 255, 255, 0.075);
        border-radius: 18px;
        background:
          linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.055),
            rgba(255, 255, 255, 0.018)
          );
      }

      .distribution-card strong,
      .process-grid strong {
        display: block;
        margin-bottom: 32px;
        color: #6888b6;
        font-size: 14px;
      }

      .distribution-card p,
      .process-grid p,
      .review-grid p {
        margin: 0;
        color: #c5cedb;
        font-size: 16px;
        line-height: 1.8;
        word-break: keep-all;
      }

      .trigger-list {
        max-width: 860px;
        margin: 0 auto;
        display: grid;
        gap: 14px;
      }

      .trigger-item {
        display: flex;
        align-items: flex-start;
        gap: 18px;
        padding: 22px 24px;
        border: 1px solid rgba(181, 198, 223, 0.1);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.03);
      }

      .trigger-item span {
        display: inline-flex;
        flex: 0 0 auto;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        color: #ffffff;
        background: #27446c;
        font-weight: 800;
      }

      .trigger-item p {
        margin: 1px 0 0;
        color: #d2dae5;
        font-size: 16px;
        line-height: 1.7;
      }

      .fact-box {
        max-width: 900px;
        margin: 0 auto;
        padding: 52px;
        border: 1px solid rgba(139, 165, 204, 0.16);
        border-radius: 22px;
        text-align: center;
        background:
          radial-gradient(
            circle at 50% 0%,
            rgba(45, 81, 137, 0.16),
            transparent 55%
          ),
          rgba(255, 255, 255, 0.025);
      }

      .fact-box p {
        max-width: 720px;
        margin: 25px auto 0;
        color: #bdc7d5;
        font-size: 17px;
        line-height: 1.9;
        white-space: pre-line;
        word-break: keep-all;
      }

      .process-grid article h3 {
        margin: 0 0 14px;
        font-size: 21px;
      }

      .review-grid blockquote {
        position: relative;
      }

      .review-grid blockquote::before {
        display: block;
        margin-bottom: 20px;
        content: '“';
        color: #5476a6;
        font-size: 46px;
        font-weight: 800;
        line-height: 0.7;
      }

      .faq-list {
        max-width: 900px;
        margin: 0 auto;
        display: grid;
        gap: 12px;
      }

      .faq-list details {
        padding: 0 24px;
