---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import CasePage from '../../components/CasePage.astro';
import { getCurrentSite } from '../../config/sites.js';
import { getCaseBySlug } from '../../lib/sheet.js';
import { getStatus } from '../../lib/utils.js';
import { buildCaseSeo, legalServiceJsonLd, caseArticleJsonLd, faqJsonLd, breadcrumbJsonLd } from '../../lib/seo.js';

export const prerender = false;
const site = getCurrentSite(Astro.url.host);
const { slug } = Astro.params;
const row = await getCaseBySlug(slug);

if (!row) {
  return new Response('페이지를 찾을 수 없습니다.', { status: 404, headers: { 'content-type': 'text/plain; charset=utf-8' } });
}

const status = getStatus(row);
if (status === 'deleted') {
  return new Response('삭제된 페이지입니다.', { status: 410, headers: { 'content-type': 'text/plain; charset=utf-8', 'x-robots-tag': 'noindex' } });
}
if (status === 'disabled' || status === 'draft') {
  return new Response('비공개 페이지입니다.', { status: 404, headers: { 'content-type': 'text/plain; charset=utf-8', 'x-robots-tag': 'noindex' } });
}
if (status === 'redirect' && row.redirectTo) {
  return Astro.redirect(row.redirectTo, 302);
}

const seo = buildCaseSeo(row, site, Astro.url);
const robots = status === 'noindex' ? 'noindex, nofollow' : 'index, follow';
const legalJson = legalServiceJsonLd(site, Astro.url);
const articleJson = caseArticleJsonLd(row, site, Astro.url, seo.canonical);
const faqJson = faqJsonLd(row);
const breadcrumbJson = breadcrumbJsonLd(row, site, Astro.url, seo.canonical);
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={robots} />
    <meta name="NaverBot" content="All" />
    <meta name="NaverBot" content="index,follow" />
    <meta name="Yeti" content="All" />
    <meta name="Yeti" content="index,follow" />
    <link rel="canonical" href={seo.canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:site_name" content={site.siteName} />
    <script type="application/ld+json" set:html={JSON.stringify(legalJson)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleJson)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJson)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />
  </head>
  <body>
    <div class="yb-page">
      <Header site={site} />
      <main><CasePage site={site} row={row} /></main>
      <Footer site={site} />
      <FloatingCTA site={site} label={`${seo.name} 피해 상담`} />
    </div>
    <script is:inline>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      document.querySelectorAll('.yb-reveal').forEach((el) => io.observe(el));
      document.querySelectorAll('.yb-faq-q').forEach((q) => {
        q.addEventListener('click', () => q.closest('.yb-faq-item').classList.toggle('open'));
        q.addEventListener('keydown', (e) => { if(e.key === 'Enter' || e.key === ' ') { e.preventDefault(); q.click(); } });
      });
    </script>
  </body>
</html>
