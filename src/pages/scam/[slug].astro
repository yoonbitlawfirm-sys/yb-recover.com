---
import '../../styles/global.css';
import CasePage from '../../components/CasePage.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import { getCurrentSite } from '../../config/sites.js';
import { getCaseBySlug, getSheetDiagnostics } from '../../lib/sheet.js';
import { getStatus, normalizeSlug } from '../../lib/utils.js';
import { buildCaseSeo, caseJsonLdGraph } from '../../lib/seo.js';
import { buildSiteCase } from '../../lib/siteCase.js';

export const prerender = false;

Astro.response.headers.set('x-yb-route-version', '20260711-routing-floating-seo-v2');
Astro.response.headers.set('cache-control', 'no-store, max-age=0');

const site = getCurrentSite(Astro.url.host);
const slug = normalizeSlug(Astro.params.slug || '');


const sourceRow = await getCaseBySlug(slug, site);
const row = sourceRow ? buildSiteCase(sourceRow, site) : null;
const diagnostics = row ? null : await getSheetDiagnostics(slug, site);

if (!row) Astro.response.status = 404;

const status = row ? getStatus(row) : 'missing';

if (status === 'deleted') Astro.response.status = 410;
if (status === 'disabled' || status === 'draft') Astro.response.status = 404;

if (status === 'redirect' && row?.redirectTo) {
  return Astro.redirect(row.redirectTo, 302);
}

const seo = row
  ? buildCaseSeo(row, site, Astro.url)
  : {
      title: `페이지를 찾을 수 없습니다 | ${site.siteName}`,
      description: '등록되지 않았거나 공개 상태가 아닌 페이지입니다.',
      canonical: new URL(`/scam/${encodeURIComponent(slug)}`, Astro.url.origin).toString(),
      keywords: [],
      name: slug || '금융사기',
      publishedAt: '',
      updatedAt: '',
      caseType: ''
    };

const robots = row && status !== 'noindex' ? 'index, follow' : 'noindex, nofollow';
const jsonLd = row ? caseJsonLdGraph(row, site, Astro.url, seo) : null;
const ogImage = `${Astro.url.origin}/images/yoonbit-og.png?v=20260710`;
const favicon = '/images/favicon.png?v=20260710';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    {seo.keywords?.length > 0 && <meta name="keywords" content={seo.keywords.join(', ')} />}
    <meta name="author" content={site.operatorName} />
    <meta name="theme-color" content={site.colors?.bg || '#02050b'} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="NaverBot" content={robots} />
    <meta name="Yeti" content={robots} />
    <link rel="canonical" href={seo.canonical} />
    <link rel="alternate" hreflang="ko-KR" href={seo.canonical} />
    <link rel="alternate" hreflang="x-default" href={seo.canonical} />
    <link rel="icon" type="image/png" href={favicon} />
    <link rel="shortcut icon" type="image/png" href={favicon} />
    <link rel="apple-touch-icon" href={favicon} />
    <meta property="og:type" content={row ? 'article' : 'website'} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seo.title} />
    <meta property="og:locale" content="ko_KR" />
    {row && seo.publishedAt && <meta property="article:published_time" content={seo.publishedAt} />}
    {row && seo.updatedAt && <meta property="article:modified_time" content={seo.updatedAt} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>

  <body>
    {row && status !== 'deleted' && status !== 'disabled' && status !== 'draft' ? (
      <CasePage site={site} row={row} />
    ) : (
      <main class="yb-cms-error">
        <section>
          <span>{status === 'deleted' ? '410' : '404'}</span>
          <h1>{status === 'deleted' ? '삭제된 페이지입니다.' : '페이지를 찾을 수 없습니다.'}</h1>
          <p>
            {status === 'draft' || status === 'disabled'
              ? '현재 비공개 상태인 페이지입니다.'
              : '등록된 주소와 게시 상태를 다시 확인해 주세요.'}
          </p>
          {diagnostics && (
            <small>
              CMS: {diagnostics.source} · 문서 {diagnostics.rowCount}개 · 도메인 {diagnostics.siteKey} · 슬러그 {diagnostics.slug}
              {diagnostics.error ? ` · ${diagnostics.error}` : ''}
            </small>
          )}
        </section>
      </main>
    )}

    <FloatingCTA site={site} label={`${seo.name || slug} 피해 상담`} />

    <style>
      .yb-cms-error {
        min-height: 72vh;
        display: grid;
        place-items: center;
        padding: 120px 24px;
        color: #fff;
        text-align: center;
        background: radial-gradient(circle at 50% 0%, rgba(47, 83, 140, .2), transparent 45%), #03070d;
      }
      .yb-cms-error section { width: min(760px, 100%); }
      .yb-cms-error span { color: #7592bd; font-weight: 800; letter-spacing: .2em; }
      .yb-cms-error h1 { margin: 18px 0 12px; font-size: clamp(32px, 5vw, 52px); }
      .yb-cms-error p { margin: 0; color: #aeb9c8; line-height: 1.8; }
      .yb-cms-error small { display: block; margin-top: 24px; color: #708095; line-height: 1.7; word-break: break-all; }
    </style>
  </body>
</html>
