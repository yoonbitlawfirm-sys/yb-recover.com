---
export const prerender = true;

const phones = [
  { label: '전화 상담 1', number: '010-8183-4252' },
  { label: '전화 상담 2', number: '010-2175-4252' },
  { label: '전화 상담 3', number: '010-2290-4252' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>전화 상담 선택</title>
    <style>
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; font-family: Arial, "Noto Sans KR", sans-serif; }
      body {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 20px;
        background: rgba(0,0,0,.72);
      }
      .popup {
        width: min(100%, 380px);
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
      }
      h1 {
        margin: 0 0 18px;
        font-size: 22px;
        text-align: center;
      }
      .buttons { display: grid; gap: 10px; }
      a {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 56px;
        border-radius: 12px;
        text-decoration: none;
        font-size: 17px;
        font-weight: 700;
        color: #fff;
        background: #111827;
      }
    </style>
  </head>
  <body>
    <main class="popup">
      <h1>전화 상담을 선택하세요</h1>
      <div class="buttons">
        {phones.map((item) => (
          <a href={`tel:${item.number.replace(/[^0-9]/g, '')}`}>
            {item.label}<br />{item.number}
          </a>
        ))}
      </div>
    </main>
  </body>
</html>
