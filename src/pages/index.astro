---
import '../styles/global.css';
import MainHome from '../components/MainHome.astro';
import { getCurrentSite } from '../config/sites.js';
import { getThemeStyle } from '../lib/theme.js';
import { buildHomeSeo, homeJsonLdGraph } from '../lib/seo.js';

export const prerender = false;

Astro.response.headers.set('x-yb-build-version', '20260711-final-v4-complete');

const site = getCurrentSite(Astro.url.host);
const seo = buildHomeSeo(site, Astro.url);
const canonicalUrl = seo.canonical;
const ogImageUrl = new URL(site.ogImage || '/images/yoonbit-og.png?v=20260711', Astro.url.origin).toString();
const pageKeywords = Array.isArray(seo.keywords) ? seo.keywords.join(', ') : '';
const robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const structuredData = homeJsonLdGraph(site, Astro.url);
const themeStyle = getThemeStyle(site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    {pageKeywords && <meta name="keywords" content={pageKeywords} />}
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="NaverBot" content={robots} />
    <meta name="Yeti" content={robots} />
    <meta name="author" content={site.operatorName} />
    <meta name="application-name" content={site.siteName} />
    <meta name="theme-color" content={site.colors?.bg || '#02050b'} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no, address=no, email=no" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ko-KR" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" type="image/png" href={site.favicon || '/images/favicon.png?v=20260711'} />
    <link rel="shortcut icon" type="image/png" href={site.favicon || '/images/favicon.png?v=20260711'} />
    <link rel="apple-touch-icon" href={site.favicon || '/images/favicon.png?v=20260711'} />
    <link rel="image_src" href={ogImageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={site.siteName} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/</g, '\\u003c')} />
  </head>

  <body class={`yb-theme yb-theme--${site.theme}`} style={themeStyle}>
    <MainHome site={site} />

    {site.siteKey === 'yb-recover' && (
      <>
        <script is:inline type="text/javascript">var hpt_info={'_account':'UHPT-300506','_server':'a300'};</script>
        <script is:inline src="//cdn.smlog.co.kr/core/smart_renew.js" charset="utf-8"></script>
        <noscript><img src="//a300.smlog.co.kr/smart_bda?_account=300506" style="display:none;width:0;height:0;" border="0" alt="" /></noscript>
      </>
    )}
  </body>
</html>
