---
import ConsultForm from './ConsultForm.astro';
import Footer from './Footer.astro';
import { cleanText } from '../lib/utils.js';

const { site = {}, row = {} } = Astro.props;

const name = cleanText(row.caseName || row.mainKeyword || row.slug || '금융사기');
const phone = site.phone || '010-2175-4252';
const telHref = site.telLink || `tel:${phone.replace(/\D/g, '')}`;
const kakaoHref = site.kakaoUrl || 'https://open.kakao.com/o/sEEHGIti';
const logo = site.logo || '/images/yoonbit-logo-cutout.png';
const siteLabel = site.shortName || '금융사기 피해회복센터';

const headline = cleanText(row.headline || `${name} 피해, 지금 남아 있는 자료부터 확인해야 합니다`);
const subHeadline = cleanText(row.subHeadline || `${name} 관련 입금내역과 대화자료가 남아 있다면 현재 피해 정황과 대응 가능성을 신속히 점검해야 합니다.`);
const heroBadge = cleanText(row.heroBadge || `${name} 피해 대응 안내`);
const eyebrow = cleanText(row.eyebrow || 'FINANCIAL FRAUD RESPONSE');
const notice = cleanText(row.noticeText || '추가 송금은 중단하고 입금내역·대화자료·계좌정보를 원본 상태로 보존하십시오.');

const risks = (Array.isArray(row.risks) && row.risks.length
  ? row.risks
  : [row.risk1, row.risk2, row.risk3])
  .map(cleanText)
  .filter(Boolean)
  .slice(0, 3);

const triggers = (Array.isArray(row.triggers) && row.triggers.length
  ? row.triggers
  : [row.trigger1, row.trigger2, row.trigger3])
  .map(cleanText)
  .filter(Boolean)
  .slice(0, 3);

const processSteps = (Array.isArray(row.processSteps) && row.processSteps.length
  ? row.processSteps
  : ['자료 보존', '자금 흐름 및 상대방 단서 확인', '민·형사 대응 절차 검토'])
  .map(cleanText)
  .filter(Boolean)
  .slice(0, 3);

const suppliedFaqs = Array.isArray(row.faqs) ? row.faqs : [];
const fallbackFaqs = [
  [`${name} 피해금을 돌려받을 수 있나요?`, '회수 가능성은 입금 시점, 자금 이동 여부, 상대방 특정 가능성과 보유 자료에 따라 달라집니다. 남아 있는 입금내역과 대화자료를 기준으로 가능한 조치부터 확인해야 합니다.'],
  ['추가 입금을 하면 출금해 준다고 합니다.', '세금, 보증금, 인증비, 계좌검증비 등 추가 송금 요구는 위험 신호일 수 있습니다. 추가 송금 전에 현재 피해 정황과 자금 흐름을 먼저 점검해야 합니다.'],
  ['자료가 일부만 있어도 상담할 수 있나요?', '가능합니다. 입금내역, 계좌정보, 대화자료, 사이트 화면 중 남아 있는 자료부터 정리해 대응 우선순위를 검토할 수 있습니다.']
];
const faqs = (suppliedFaqs.length ? suppliedFaqs : fallbackFaqs)
  .map((item) => [cleanText(item?.[0]), cleanText(item?.[1])])
  .filter(([question, answer]) => question && answer)
  .slice(0, 6);

const warningLabels = ['즉시 확인', '자료 보존', '추가 피해 차단'];
const proofLabels = ['사실관계 정리', '법적 절차 검토', '회복 가능성 판단'];
const preparationItems = [
  '입금내역·이체확인증·계좌번호·예금주',
  '카카오톡·텔레그램·문자·이메일 대화자료',
  '사이트 주소·출금 제한 화면·담당자 연락처',
  '추가 입금 요구 내용과 사건 진행 시간순 정리'
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer
    }
  }))
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${name} 피해 의심 시 대응 준비 방법`,
  description: `${name} 피해가 의심될 때 입금자료와 대화자료를 보존하고 대응 가능성을 확인하기 위한 기본 절차입니다.`,
  totalTime: 'PT5M',
  step: processSteps.map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    name: step,
    text: risks[index] || triggers[index] || step
  }))
};
---

<div class="yb-case-page">
  <a class="yb-case-back" href="/" aria-label="발사대로 돌아가기">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M15 18l-6-6 6-6"></path>
    </svg>
    <span>돌아가기</span>
  </a>

  <main>
    <section class="yb-case-hero" aria-labelledby="yb-case-title">
      <div class="yb-case-background" aria-hidden="true">
        <div class="yb-case-background__panel yb-case-background__panel--left"></div>
        <div class="yb-case-background__panel yb-case-background__panel--right"></div>
        <div class="yb-case-background__panel yb-case-background__panel--bottom"></div>
        <div class="yb-case-background__grid"></div>
        <div class="yb-case-background__glow"></div>
      </div>

      <div class="yb-case-hero__content">
        <div class="yb-case-logo">
          <span aria-hidden="true"></span>
          <img src={logo} alt="법무법인 윤빛" width="760" height="365" loading="eager" decoding="async" />
        </div>

        <p class="yb-case-hero__eyebrow">{eyebrow}</p>
        <div class="yb-case-hero__badge">{heroBadge}</div>
        <h1 id="yb-case-title">{headline}</h1>
        <p class="yb-case-hero__lead">{subHeadline}</p>

        <div class="yb-case-hero__actions" aria-label="상담 연결">
          <a class="primary" href="#consult">골든타임을 놓치지 마세요</a>
          <a href={telHref}>{phone}</a>
          <a href={kakaoHref} target="_blank" rel="noopener noreferrer">카카오 상담</a>
        </div>
      </div>
    </section>

    <section class="yb-case-section" id="paid">
      <div class="yb-case-inner yb-case-split">
        <div class="yb-case-copy">
          <p>IF YOU PAID</p>
          <h2>{row.sectionTitle || `${name} 피해 정황 확인`}</h2>
          <span>{notice}</span>
          <a class="yb-case-text-link" href={telHref}>{phone} 전화 상담하기 <b aria-hidden="true">→</b></a>
        </div>

        <div class="yb-case-mini-grid">
          {(triggers.length ? triggers : risks).map((item, index) => (
            <article class="yb-case-mini-card">
              <i>{String(index + 1).padStart(2, '0')}</i>
              <strong>{warningLabels[index] || `확인 ${index + 1}`}</strong>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="yb-case-section yb-case-section--alt" id="recovery">
      <div class="yb-case-inner">
        <div class="yb-case-heading">
          <p>RECOVERY CHECK</p>
          <h2>{site.content?.sectionTitle || '피해회복 가능성을 확인하는 핵심 기준'}</h2>
          <span>{row.factBody || `${siteLabel}는 남아 있는 입금내역과 대화자료를 기준으로 대응 우선순위를 검토합니다.`}</span>
        </div>

        <div class="yb-case-card-grid">
          {risks.map((item, index) => (
            <a class="yb-case-card" href="#consult">
              <i>{String(index + 1).padStart(2, '0')}</i>
              <strong>{['피해 정황', '자금 흐름', '대응 가능성'][index] || `점검 ${index + 1}`}</strong>
              <p>{item}</p>
              <span aria-hidden="true">상담 신청 →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="yb-case-section" id="proof">
      <div class="yb-case-inner">
        <div class="yb-case-heading">
          <p>PROOF OF RESPONSE</p>
          <h2>{row.factTitle || '정확한 사실관계 정리가 대응 방향을 좌우합니다'}</h2>
          <span>{row.factBody || '같은 피해 유형이라도 자금 흐름과 증거 상태에 따라 필요한 대응 순서가 달라집니다.'}</span>
        </div>

        <div class="yb-case-proof-grid">
          {processSteps.map((step, index) => (
            <article class="yb-case-proof-card">
              <i>{String(index + 1).padStart(2, '0')}</i>
              <strong>{proofLabels[index] || step}</strong>
              <h3>{step}</h3>
              <p>{risks[index] || triggers[index] || '남아 있는 자료를 기준으로 필요한 대응 절차를 확인합니다.'}</p>
            </article>
          ))}
        </div>

        <div class="yb-case-proof-note">
          <strong>중요 안내</strong>
          <p>추가 송금을 요구받고 있다면 먼저 입금을 중단하고, 화면·대화방·계좌정보가 사라지기 전에 원본 자료를 보존해야 합니다.</p>
        </div>
      </div>
    </section>

    <section class="yb-case-section yb-case-section--alt" id="consult">
      <div class="yb-case-inner yb-case-consult-layout">
        <div class="yb-case-copy">
          <p>CONSULTATION</p>
          <h2>{row.processTitle || site.content?.processTitle || '남아 있는 자료를 기준으로 대응 순서를 확인합니다'}</h2>
          <span>상담 접수 시 현재 보유한 자료와 피해 진행 상황을 함께 남겨주시면 사실관계 확인에 도움이 됩니다.</span>

          <div class="yb-case-preparation">
            <h3>상담 전 준비하면 좋은 자료</h3>
            <ul>
              {preparationItems.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>

        <div class="yb-case-consult-form">
          <ConsultForm site={site} caseName={`${name} 피해 정황 상담`} />
        </div>
      </div>
    </section>

    <section class="yb-case-section" id="faq-list">
      <div class="yb-case-inner">
        <div class="yb-case-heading">
          <p>Q&amp;A</p>
          <h2>{name} 피해 상담 전 자주 묻는 질문</h2>
        </div>

        <div class="yb-case-faq-list">
          {faqs.map(([question, answer], index) => (
            <details class="yb-case-faq">
              <summary>
                <i>{String(index + 1).padStart(2, '0')}</i>
                <strong>{question}</strong>
                <em aria-hidden="true">+</em>
              </summary>
              <p>{answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="yb-case-legal-notice" aria-label="사칭 피해 예방 및 상담 절차 고지">
      <div class="yb-case-inner">
        <div class="yb-case-legal-notice__box">
          <h2>사칭 피해 예방 및 상담 절차 고지</h2>
          <p>법무법인 윤빛은 상담 전 피해금 회수 성공을 보장하거나, 수임료 외 별도의 보증금·인증비·계좌검증비를 요구하지 않습니다.</p>
          <p>수사기관·금융기관·법률전문가를 사칭해 원격제어 앱 설치, 인증번호 전달, 추가 송금을 요구하는 연락에 주의하십시오.</p>
          <p>개별 사건의 대응 가능성과 결과는 사실관계, 증거자료, 자금 이동 상태 및 관계기관의 판단에 따라 달라질 수 있습니다.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer site={site} />
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema).replace(/</g, '\\u003c')} />
<script type="application/ld+json" set:html={JSON.stringify(howToSchema).replace(/</g, '\\u003c')} />

<style>
  .yb-case-page {
    min-height: 100vh;
    overflow: hidden;
    background: var(--yb-bg);
    color: var(--yb-text);
  }

  .yb-case-back {
    position: fixed;
    z-index: 100;
    left: max(18px, env(safe-area-inset-left));
    top: max(18px, env(safe-area-inset-top));
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 0 15px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(2, 5, 11, 0.68);
    color: rgba(255, 255, 255, 0.78);
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.28);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    font-size: 13px;
    font-weight: 520;
    letter-spacing: -0.025em;
    transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .yb-case-back:hover {
    color: #fff;
    border-color: var(--yb-accent-2);
    transform: translateY(-1px);
  }

  .yb-case-back:focus-visible {
    outline: 3px solid var(--yb-accent-2);
    outline-offset: 3px;
  }

  .yb-case-back svg {
    width: 16px;
    height: 16px;
  }

  .yb-case-inner {
    width: min(1120px, calc(100% - 44px));
    margin: 0 auto;
  }

  .yb-case-hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    isolation: isolate;
    overflow: hidden;
    padding: 90px 22px 74px;
    background:
      radial-gradient(circle at 74% 70%, var(--yb-accent-soft), transparent 34%),
      linear-gradient(135deg, var(--yb-bg-deep) 0%, var(--yb-bg) 40%, var(--yb-bg-mid) 72%, var(--yb-bg-deep) 100%);
  }

  .yb-case-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.72), transparent 31%, transparent 69%, rgba(0, 0, 0, 0.60)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.48));
    pointer-events: none;
  }

  .yb-case-background {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .yb-case-background__panel {
    position: absolute;
    border: 1px solid rgba(255, 255, 255, 0.035);
  }

  .yb-case-background__panel--left {
    left: -5%;
    top: 28%;
    width: 28%;
    height: 48%;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.045), transparent 62%),
      var(--yb-surface);
    opacity: 0.82;
  }

  .yb-case-background__panel--right {
    right: -3%;
    top: 27%;
    width: 31%;
    height: 51%;
    background:
      linear-gradient(145deg, var(--yb-secondary-soft), transparent 68%),
      var(--yb-bg-mid);
    opacity: 0.90;
  }

  .yb-case-background__panel--bottom {
    left: 34%;
    bottom: -11%;
    width: 32%;
    height: 36%;
    background:
      linear-gradient(180deg, var(--yb-accent-soft), transparent 72%),
      var(--yb-surface);
    opacity: 0.56;
  }

  .yb-case-background__grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.014) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
    background-size: 82px 82px;
    opacity: 0.38;
  }

  .yb-case-background__glow {
    position: absolute;
    width: min(72vw, 760px);
    aspect-ratio: 1;
    left: 50%;
    top: 52%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, var(--yb-accent-glow), transparent 67%);
    filter: blur(18px);
    opacity: 0.15;
  }

  .yb-case-hero__content {
    position: relative;
    z-index: 2;
    width: min(980px, 100%);
    margin: 0 auto;
    text-align: center;
  }

  .yb-case-logo {
    position: relative;
    width: 180px;
    height: 138px;
    margin: 0 auto 18px;
    display: grid;
    place-items: center;
  }

  .yb-case-logo::before,
  .yb-case-logo::after,
  .yb-case-logo > span {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid var(--yb-line);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .yb-case-logo::before {
    width: 154px;
    height: 154px;
    opacity: 0.58;
  }

  .yb-case-logo::after {
    width: 124px;
    height: 124px;
    opacity: 0.40;
  }

  .yb-case-logo > span {
    width: 94px;
    height: 94px;
    opacity: 0.28;
  }

  .yb-case-logo img {
    position: relative;
    z-index: 1;
    width: 176px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 10px 22px rgba(0, 0, 0, 0.32));
  }

  .yb-case-hero__eyebrow {
    margin: 0 0 15px;
    color: var(--yb-accent-2);
    font-size: clamp(11px, 1.4vw, 13px);
    font-weight: 800;
    line-height: 1.4;
    letter-spacing: 0.20em;
    text-transform: uppercase;
  }

  .yb-case-hero__badge {
    width: fit-content;
    max-width: 100%;
    margin: 0 auto 13px;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(14px, 1.8vw, 18px);
    font-weight: 620;
    line-height: 1.45;
    letter-spacing: -0.035em;
  }

  .yb-case-hero h1 {
    max-width: 960px;
    margin: 0 auto;
    color: #fff;
    font-size: clamp(42px, 6.4vw, 76px);
    font-weight: 650;
    line-height: 1.12;
    letter-spacing: -0.07em;
    text-wrap: balance;
  }

  .yb-case-hero__lead {
    max-width: 830px;
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.64);
    font-size: clamp(15px, 1.85vw, 18px);
    font-weight: 350;
    line-height: 1.82;
    letter-spacing: -0.035em;
    text-wrap: pretty;
  }

  .yb-case-hero__actions {
    width: min(100%, 760px);
    margin: 31px auto 0;
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    gap: 10px;
  }

  .yb-case-hero__actions a {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    background: rgba(2, 5, 11, 0.64);
    color: rgba(255, 255, 255, 0.87);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.03em;
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition: transform 160ms ease, border-color 160ms ease, filter 160ms ease;
  }

  .yb-case-hero__actions a.primary {
    border-color: var(--yb-accent-2);
    background: linear-gradient(135deg, var(--yb-accent), var(--yb-accent-strong));
    color: var(--yb-on-accent);
    box-shadow: 0 16px 38px var(--yb-accent-soft);
  }

  .yb-case-hero__actions a:hover {
    transform: translateY(-1px);
    border-color: var(--yb-accent-2);
    filter: brightness(1.08);
  }

  .yb-case-hero__actions a:focus-visible {
    outline: 3px solid var(--yb-accent-2);
    outline-offset: 3px;
  }

