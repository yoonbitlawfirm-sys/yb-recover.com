---
import ConsultForm from './ConsultForm.astro';
import { cleanText } from '../lib/utils.js';

const { site = {}, row = {} } = Astro.props;

const name = cleanText(row.caseName || row.mainKeyword || row.slug || '금융사기');

const theme = site?.theme || 'main';

const kakao = site?.kakaoUrl || 'https://open.kakao.com/o/sEEHGIti';
const phone = site?.phone || '010-2175-4252';
const telHref = site?.telLink || `tel:${phone.replace(/\D/g, '')}`;
const logo = site?.logo || '/images/yoonbit-logo-cutout.png';
const isRecover = site?.siteKey === 'yb-recover';
const siteLabel = site?.siteName || '금융피해 대응센터';
const content = site?.content || {};
const operator = site?.operatorName || '법무법인 윤빛';

const recoveryChecks = [
  [
    '01',
    '입금 흐름 확인',
    '입금 계좌, 예금주, 지갑주소, 송금 시점과 명목을 먼저 정리합니다. 대포통장을 거쳐 자금이 분산되기 전, 자금 흐름을 잡는 것이 회수 가능성 검토의 출발점입니다.'
  ],
  [
    '02',
    '상대방 특정 단서',
    '담당자 이름, 연락처, 대화방, 사이트 주소, 입금 계좌, 예금주 등 상대방을 특정할 단서가 남아 있는지 확인합니다. 단서가 사라지기 전 보존하는 것이 중요합니다.'
  ],
  [
    '03',
    '법적 대응 가능성',
    '자금 추적, 지급정지, 고소, 가압류, 손해배상, 합의 가능성을 함께 검토합니다. 단순 신고에 그치지 않고 원금 회수 가능성을 높이는 방향으로 대응합니다.'
  ]
];

const warningCards = [
  [
    '01',
    '출금 지연',
    '출금 신청 후 처리 중이라는 답변만 반복되거나 승인 시간이 계속 미뤄지는 경우입니다. 이 단계에서 계좌·사이트 단서가 사라지기 전 자료 보존이 필요합니다.'
  ],
  [
    '02',
    '추가 입금 요구',
    '세금, 인증비, 보증금, 수수료, 계좌검증비 등의 명목으로 추가 송금을 요구받는 경우입니다. 추가 입금 전 피해 정황부터 확인해야 합니다.'
  ],
  [
    '03',
    '연락두절',
    '담당자 답변이 늦어지거나 대화방이 사라지고 사이트 접속이 제한되는 경우입니다. 연락두절 전후의 자료가 대응 방향을 좌우할 수 있습니다.'
  ]
];

const proofCards = [
  [
    '01',
    '자료 기준 검토',
    '입금내역, 대화자료, 사이트 화면, 계좌정보를 기준으로 현재 피해 유형과 대응 우선순위를 정리합니다.'
  ],
  [
    '02',
    '민·형사 절차 검토',
    '상대방 특정 가능성과 자금 이동 흐름을 기준으로 형사 고소, 지급정지, 가압류, 손해배상 가능성을 함께 확인합니다.'
  ],
  [
    '03',
    '회수 가능성 판단',
    '대포통장을 통한 자금세탁 가능성과 남아 있는 증거를 기준으로 회수 가능성을 높일 대응 방향을 검토합니다.'
  ]
];

const faqs = [
  [
    '이미 입금한 돈을 돌려받을 수 있나요?',
    `회수 가능성은 입금 계좌, 자금 이동 속도, 상대방 특정 가능성, 증거자료 상태에 따라 달라집니다. ${siteLabel}는 ${name} 관련 남아 있는 자료를 기준으로 지급정지·고소·가압류·손해배상 등 대응 가능성부터 확인합니다.`
  ],
  [
    '경찰 신고만 하면 원금이 돌아오나요?',
    '경찰 신고는 수사의 출발점입니다. 원금 회수 가능성을 높이려면 입금 흐름, 대포통장 여부, 상대방 특정 단서, 민·형사 절차 가능성을 함께 검토해야 합니다.'
  ],
  [
    '추가 입금을 하면 출금이 가능하다고 합니다.',
    '세금, 인증비, 보증금, 계좌검증비 명목의 추가 입금 요구는 위험 신호일 수 있습니다. 추가 송금 전 현재 정황과 자료 상태를 먼저 확인해야 합니다.'
  ],
  [
    '자료가 부족해도 상담 가능한가요?',
    '가능합니다. 입금내역, 대화자료, 사이트 화면, 계좌정보 중 일부만 있어도 피해 정황을 정리하고 우선 대응 방향을 검토할 수 있습니다.'
  ]
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer
    }
  }))
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${name} 피해 의심 시 대응 가능성 확인 방법`,
  description: `${name} 피해가 의심될 때 입금내역, 대화자료, 계좌정보를 기준으로 대응 가능성을 확인하는 절차입니다.`,
  totalTime: 'PT5M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: '입금자료 보존',
      text: '입금내역, 이체확인증, 계좌번호, 예금주, 지갑주소 등 자금 이동 경로를 확인할 자료를 보존합니다.'
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: '대화자료 저장',
      text: '카카오톡, 텔레그램, 문자, 사이트 상담창, 추가 입금 요구 내용을 삭제하지 않고 캡처합니다.'
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: '법적 조치 검토',
      text: '지급정지, 고소, 가압류, 손해배상, 합의 가능성을 함께 검토해 대응 방향을 정리합니다.'
    }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${name} 피해 대응 | ${siteLabel}`,
  description: `${name} 관련 입금을 하신 상황이라면 출금 지연, 추가 입금 요구, 연락두절 정황을 기준으로 빠른 법적 대응 가능성을 확인합니다.`,
  inLanguage: 'ko-KR',
  about: {
    '@type': 'Thing',
    name: `${name} 피해 정황 및 대응 가능성`
  }
};
---

<style is:global>
  header,
  nav,
  .site-header,
  .yb-header,
  .global-header,
  .main-header,
  .top-header,
  .navbar,
  .gnb,
  .header,
  .header-wrap,
  .nav-wrap,
  .navigation,
  .desktop-nav,
  .mobile-nav,
  .top-floating,
  .top-fixed,
  .fixed-top,
  .floating-top,
  .reservation-bar,
  .consult-reserve,
  .reserve-button,
  .bottom-floating,
  .floating-cta,
  .bottom-cta,
  .sticky-cta,
  .fixed-cta,
  .mobile-cta,
  .consult-floating,
  .floating-consult,
  .quick-consult,
  .quick-cta,
  .cta-fixed,
  .fixed-bottom,
  .bottom-bar,
  .floating-bar,
  .contact-floating,
  .floating-bottom,
  .bottom-consult,
  .consult-bar,
  .sticky-bottom,
  .floating-call,
  .call-floating,
  .fixed-consult-bar,
  .floating-actions,
  .fixed-actions,
  .fixed-contact,
  .floating-contact,
  .bottom-buttons,
  .bottom-button-wrap,
  .bottom-action-bar,
  .bottom-fixed-cta,
  .mobile-bottom-fixed,
  .mobile-bottom-cta,
  .mobile-fixed-bottom,
  .quick-buttons,
  .quick-action-buttons,
  .call-kakao-floating,
  .call-kakao-bar,
  .contact-actions,
  .contact-action-bar,
  .tel-kakao-bar,
  .phone-kakao-bar {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  footer:not(.yb-shot-footer),
  .site-footer,
  .global-footer,
  .main-footer,
  .footer,
  .footer-wrap,
  .copyright,
  .page-footer {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  html,
  body {
    margin: 0 !important;
    padding: 0 !important;
    overflow-x: hidden;
    background: var(--site-bg, #02050b);
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
  }
</style>

<style>
  .yb-shot-page {
    min-height: 100vh;
    background: var(--site-bg, #02050b);
    color: var(--site-text, #ffffff);
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
    overflow-x: hidden;
    padding-bottom: 92px;
  }

  .yb-shot-page * {
    box-sizing: border-box;
  }

  .yb-shot-back {
    position: absolute;
    top: 22px;
    left: 22px;
    z-index: 50;
    height: 42px;
    padding: 0 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(4, 8, 16, 0.62);
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 13px;
    font-weight: 300;
    letter-spacing: -0.035em;
    backdrop-filter: blur(14px);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.24);
  }

  .yb-shot-back svg {
    width: 16px;
    height: 16px;
  }

  .yb-shot-inner {
    width: min(1120px, calc(100% - 44px));
    margin: 0 auto;
  }

  .yb-shot-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(circle at 72% 68%, rgba(31, 67, 142, 0.055), transparent 34%),
      linear-gradient(135deg, #02050b 0%, #040914 42%, #07101d 72%, #02050b 100%);
  }

  .yb-shot-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.78), transparent 31%, transparent 69%, rgba(0, 0, 0, 0.68)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.48));
    pointer-events: none;
  }

  .yb-shot-hero::after,
  .yb-shot-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.014) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
    background-size: 84px 84px;
    opacity: 0.34;
    pointer-events: none;
  }

  .yb-shot-panel-a,
  .yb-shot-panel-b,
  .yb-shot-panel-c {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .yb-shot-panel-a {
    left: 0;
    top: 24%;
    width: 22vw;
    height: 45vh;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.004)),
      linear-gradient(180deg, rgba(8, 15, 31, 0.82), rgba(4, 8, 16, 0.96));
    border: 1px solid rgba(255, 255, 255, 0.035);
    animation: ybPanelDriftA 9s ease-in-out infinite;
  }

  .yb-shot-panel-b {
    right: 0;
    top: 22%;
    width: 24vw;
    height: 38vh;
    background:
      radial-gradient(circle at 50% 40%, rgba(31, 67, 142, 0.12), transparent 45%),
      linear-gradient(180deg, rgba(8, 20, 47, 0.9), rgba(5, 10, 20, 0.94));
    border: 1px solid rgba(255, 255, 255, 0.035);
    animation: ybPanelDriftB 10s ease-in-out infinite;
  }

  .yb-shot-panel-c {
    left: 34%;
    bottom: 0;
    width: 32vw;
    height: 24vh;
    background:
      radial-gradient(circle at 50% 44%, rgba(31, 67, 142, 0.08), transparent 48%),
      linear-gradient(180deg, rgba(10, 22, 46, 0.72), rgba(4, 8, 16, 0.98));
    border: 1px solid rgba(255, 255, 255, 0.035);
    animation: ybPanelDriftC 11s ease-in-out infinite;
  }

  .yb-shot-hero-content {
    position: relative;
    z-index: 3;
    width: min(720px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
    transform: translateY(-2vh);
    animation: ybHeroRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .yb-shot-logo-wrap {
    position: relative;
    width: 176px;
    height: 176px;
    margin: 0 auto 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(4, 8, 16, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.095);
    box-shadow:
      0 26px 62px rgba(0, 0, 0, 0.36),
      0 0 0 1px rgba(201, 164, 92, 0.055),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
    backdrop-filter: blur(16px);
    animation: ybLogoFloat 5.8s ease-in-out infinite;
  }

  .yb-shot-logo-wrap::before {
    content: "";
    position: absolute;
    inset: -15px;
    border-radius: 50%;
    border: 1px solid rgba(201, 164, 92, 0.16);
    background: radial-gradient(circle, rgba(201, 164, 92, 0.075), transparent 62%);
    opacity: 0.72;
    animation: ybSoftPulse 3.8s ease-in-out infinite;
  }

  .yb-shot-logo-wrap::after {
    content: "";
    position: absolute;
    inset: 17px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }

  .yb-shot-logo {
    position: relative;
    z-index: 1;
    width: 158px;
    height: 158px;
    max-width: 158px;
    max-height: 158px;
    object-fit: contain;
    opacity: 0.98;
    transform: scale(1.62);
    transform-origin: center;
    filter: drop-shadow(0 14px 24px rgba(0, 0, 0, 0.42));
  }

  .yb-shot-kicker {
    margin: 0 0 18px;
    color: rgba(201, 164, 92, 0.82);
    font-size: clamp(13px, 1.62vw, 16px);
    font-weight: 500;
    letter-spacing: 0.26em;
    line-height: 1.45;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-hero h1,
  .yb-shot-head h2,
  .yb-shot-copy h2 {
    margin: 0;
    color: rgba(255, 255, 255, 0.96);
    font-weight: 500;
    letter-spacing: -0.065em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-hero h1 {
    font-size: clamp(38px, 5.8vw, 62px);
    line-height: 1.12;
  }

  .yb-shot-hero h1 .yb-shot-title-line {
    display: block;
    white-space: nowrap;
  }

  .yb-shot-hero-copy {
    width: min(92vw, 620px);
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: clamp(15px, 1.7vw, 18px);
    font-weight: 300;
    line-height: 1.75;
    letter-spacing: -0.035em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-hero-actions {
    width: min(520px, 100%);
    margin: 34px auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .yb-shot-action {
    position: relative;
    overflow: hidden;
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.13);
    color: rgba(255, 255, 255, 0.86);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -0.035em;
    text-decoration: none;
    background: rgba(4, 8, 16, 0.66);
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(16px);
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease;
  }

  .yb-shot-action::before,
  .yb-shot-fixed-action::before {
    content: "";
    position: absolute;
    top: 0;
    left: -75%;
    width: 48%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.14), transparent);
    transform: skewX(-18deg);
    transition: left 0.62s ease;
    pointer-events: none;
  }

  .yb-shot-action:hover::before,
  .yb-shot-fixed-action:hover::before {
    left: 125%;
  }

  .yb-shot-action:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 20px 54px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
  }

  .yb-shot-action.primary {
    border-color: rgba(166, 28, 39, 0.42);
    background: rgba(166, 28, 39, 0.88);
    color: var(--site-text, #ffffff);
    box-shadow: 0 14px 34px rgba(139, 18, 28, 0.28);
  }

  .yb-shot-section {
    position: relative;
    padding: 92px 0;
    background:
      radial-gradient(circle at 82% 12%, rgba(31, 67, 142, 0.055), transparent 34%),
      linear-gradient(180deg, #02050b 0%, #050914 100%);
    overflow: hidden;
  }

  .yb-shot-section.alt {
    background:
      radial-gradient(circle at 12% 10%, rgba(201, 164, 92, 0.038), transparent 32%),
      linear-gradient(180deg, #050914 0%, #02050b 100%);
  }

  .yb-shot-head {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: 36px;
  }

  .yb-shot-head p,
  .yb-shot-copy p {
    margin: 0 0 14px;
    color: rgba(201, 164, 92, 0.82);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-align: center;
  }

  .yb-shot-head h2,
  .yb-shot-copy h2 {
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1.26;
  }

  .yb-shot-head span,
  .yb-shot-copy span {
    display: block;
    width: min(100%, 680px);
    margin: 18px auto 0;
    color: rgba(255, 255, 255, 0.64);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.78;
    letter-spacing: -0.035em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-grid-3,
  .yb-shot-proof-grid,
  .yb-shot-faq-grid {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 14px;
  }

  .yb-shot-grid-3,
  .yb-shot-proof-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .yb-shot-faq-grid {
    grid-template-columns: 1fr;
    width: min(100%, 860px);
    margin: 0 auto;
  }

  .yb-shot-card,
  .yb-shot-mini,
  .yb-shot-consult,
  .yb-shot-faq,
  .yb-shot-live {
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.105);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.012)),
      rgba(4, 8, 16, 0.72);
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.035);
    backdrop-filter: blur(14px);
  }

  .yb-shot-card,
  .yb-shot-mini {
    position: relative;
    overflow: hidden;
    display: block;
    min-height: 190px;
    padding: 26px 24px;
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.34s ease,
      background 0.34s ease,
      box-shadow 0.34s ease;
  }

  .yb-shot-card::before,
  .yb-shot-mini::before,
  .yb-shot-consult::before,
  .yb-shot-live::before,
  .yb-shot-faq::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 18% 0%, rgba(201, 164, 92, 0.075), transparent 38%);
    opacity: 0;
    transition: opacity 0.32s ease;
    pointer-events: none;
  }

  .yb-shot-card:hover,
  .yb-shot-mini:hover {
    transform: translateY(-6px);
    border-color: rgba(201, 164, 92, 0.22);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.014)),
      rgba(5, 10, 20, 0.78);
    box-shadow:
      0 32px 86px rgba(0, 0, 0, 0.32),
      0 0 0 1px rgba(201, 164, 92, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
  }

  .yb-shot-card:hover::before,
  .yb-shot-mini:hover::before,
  .yb-shot-consult:hover::before,
  .yb-shot-live:hover::before,
  .yb-shot-faq:hover::before {
    opacity: 1;
  }

  .yb-shot-card i,
  .yb-shot-mini i {
    display: block;
    margin-bottom: 22px;
    color: rgba(201, 164, 92, 0.86);
    font-style: normal;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.18em;
  }

  .yb-shot-card strong,
  .yb-shot-mini strong {
    display: block;
    margin-bottom: 12px;
    color: rgba(255, 255, 255, 0.94);
    font-size: 21px;
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 1.3;
  }

  .yb-shot-card p,
  .yb-shot-mini p {
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.72;
    letter-spacing: -0.035em;
    word-break: keep-all;
  }

  .yb-shot-split {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: 34px;
    align-items: center;
  }

  .yb-shot-copy {
    text-align: center;
  }

  .yb-shot-mini-grid,
  .yb-shot-consult-stack {
    display: grid;
    gap: 14px;
  }

  .yb-shot-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 46px;
    margin: 28px auto 0;
    padding: 0 22px;
    border-radius: 999px;
    border: 1px solid rgba(166, 28, 39, 0.34);
    background: rgba(166, 28, 39, 0.82);
    color: var(--site-text, #ffffff);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -0.035em;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(139, 18, 28, 0.22);
  }

  .yb-shot-proof-note {
    position: relative;
    z-index: 2;
    margin-top: 18px;
    padding: 16px 18px;
    border-radius: 16px;
    border: 1px solid rgba(201, 164, 92, 0.14);
    background: rgba(201, 164, 92, 0.045);
    color: rgba(255, 255, 255, 0.52);
    font-size: 12px;
    font-weight: 300;
    line-height: 1.72;
    letter-spacing: -0.025em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-consult {
    padding: 26px;
  }


  .yb-shot-consult-after {
    margin: 14px 4px 0;
    padding: 14px 15px;
    border-radius: 16px;
    border: 1px solid rgba(201, 164, 92, 0.14);
    background: rgba(201, 164, 92, 0.045);
    color: rgba(255, 255, 255, 0.58);
    font-size: 12.5px;
    font-weight: 300;
    line-height: 1.62;
    letter-spacing: -0.035em;
    text-align: center;
    word-break: keep-all;
  }

  .yb-shot-live {
    position: relative;
    overflow: hidden;
    padding: 22px;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.105);
    background:
      radial-gradient(circle at 78% 0%, rgba(31, 67, 142, 0.095), transparent 36%),
      linear-gradient(180deg, rgba(7, 12, 24, 0.96), rgba(3, 6, 13, 0.98));
  }

  .yb-shot-live-head {
    position: relative;
    z-index: 2;
    margin-bottom: 14px;
    padding-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.11);
  }

  .yb-shot-live-title {
    width: 100%;
    text-align: center;
  }

  .yb-shot-live-title small {
    display: block;
    margin-bottom: 7px;
    color: rgba(201, 164, 92, 0.78);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
  }

  .yb-shot-live-title h3 {
    margin: 0;
    color: rgba(255, 255, 255, 0.96);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1.25;
  }


  .yb-shot-live-viewport {
    position: relative;
    z-index: 2;
    height: 432px;
    overflow: hidden;
    transform: translateZ(0);
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 4%,
      #000 95%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 4%,
      #000 95%,
      transparent 100%
    );
  }

  :global(.yb-shot-live-list) {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    display: grid !important;
    gap: 12px !important;
    animation: ybLiveScroll 58s linear infinite !important;
    transform: translate3d(0, 0, 0);
    -webkit-transform: translate3d(0, 0, 0);
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .yb-shot-live:hover :global(.yb-shot-live-list) {
    animation-play-state: paused;
  }

  :global(.yb-shot-live-item) {
    position: relative !important;
    overflow: hidden !important;
    min-height: 70px !important;
    padding: 0 16px !important;
    display: grid !important;
    grid-template-columns: minmax(0, 1fr) auto !important;
    align-items: center !important;
    gap: 14px !important;
    border-radius: 18px !important;
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.038), rgba(255, 255, 255, 0.012)),
      rgba(5, 8, 16, 0.78) !important;
    box-shadow:
      0 16px 36px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.035) !important;
    transition:
      transform 0.26s ease,
      border-color 0.26s ease,
      background 0.26s ease !important;
  }

  :global(.yb-shot-live-item::before) {
    content: "" !important;
    position: absolute !important;
    left: 0 !important;
    top: 18px !important;
    bottom: 18px !important;
    width: 2px !important;
    border-radius: 99px !important;
    background: rgba(201, 164, 92, 0.62) !important;
  }

  :global(.yb-shot-live-item:hover) {
    transform: translateX(4px) !important;
    border-color: rgba(201, 164, 92, 0.2) !important;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.048), rgba(255, 255, 255, 0.014)),
      rgba(7, 12, 24, 0.84) !important;
  }


  :global(.yb-shot-live-title-text) {
    display: block !important;
    min-width: 0 !important;
    color: rgba(255, 255, 255, 0.96) !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    letter-spacing: -0.05em !important;
    line-height: 1.35 !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
  }

  :global(.yb-shot-live-time) {
    color: rgba(255, 255, 255, 0.44) !important;
    font-size: 12px !important;
    font-weight: 400 !important;
    letter-spacing: -0.035em !important;
    white-space: nowrap !important;
  }


  @keyframes ybLiveScroll {
    0% {
      transform: translateY(0);
    }

    100% {
      transform: translateY(-50%);
    }
  }

  #faq-list {
    padding-top: 78px;
    padding-bottom: 76px;
  }

  #faq-list .yb-shot-head {
    margin-bottom: 26px;
  }

  #faq-list .yb-shot-head h2 {
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.06em;
  }

  .yb-shot-faq-grid {
    width: min(100%, 780px);
    gap: 12px;
  }

  .yb-shot-faq {
    overflow: hidden;
    border-radius: 18px;
  }

  .yb-shot-faq summary {
    list-style: none;
    cursor: pointer;
    min-height: 66px;
    padding: 18px 20px;
    display: grid;
    grid-template-columns: 38px 1fr 24px;
    gap: 10px;
    align-items: center;
  }

  .yb-shot-faq summary::-webkit-details-marker {
    display: none;
  }

  .yb-shot-faq i {
    color: rgba(201, 164, 92, 0.88);
    font-style: normal;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  .yb-shot-faq strong {
    display: block;
    color: rgba(255, 255, 255, 0.93);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1.32;
  }

  .yb-shot-faq em {
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    justify-self: end;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.115);
    color: rgba(255, 255, 255, 0.52);
    font-style: normal;
    font-size: 15px;
    font-weight: 300;
    line-height: 1;
  }

  .yb-shot-faq[open] em {
    transform: rotate(45deg);
  }

  .yb-shot-faq p {
    margin: 0;
    padding: 0 20px 20px 68px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    font-weight: 300;
    line-height: 1.65;
    letter-spacing: -0.035em;
    word-break: keep-all;
  }


  .yb-shot-notice-section {
    position: relative;
    z-index: 2;
    padding: 0 0 72px;
    background: var(--site-bg, #02050b);
  }

  .yb-shot-notice {
    position: relative;
    overflow: hidden;
    width: min(860px, 100%);
    margin: 0 auto;
    padding: 26px 26px 28px;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.105);
    background:
      radial-gradient(circle at 10% 0%, rgba(201, 164, 92, 0.055), transparent 32%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.043), rgba(255, 255, 255, 0.01)),
      rgba(4, 8, 16, 0.82);
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.035);
    backdrop-filter: blur(14px);
  }

  .yb-shot-notice::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(201, 164, 92, 0.08), transparent 34%, transparent 66%, rgba(31, 67, 142, 0.05));
    opacity: 0.7;
  }

  .yb-shot-notice-title {
    position: relative;
    z-index: 2;
    margin: 0 0 18px;
    display: flex;
    align-items: center;
    gap: 9px;
    color: rgba(201, 164, 92, 0.94);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.45;
  }

  .yb-shot-notice-title::before {
    content: "";
    flex: 0 0 auto;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(201, 164, 92, 0.95);
    box-shadow: 0 0 0 5px rgba(201, 164, 92, 0.09);
  }

  .yb-shot-notice p {
    position: relative;
    z-index: 2;
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.82;
    letter-spacing: -0.035em;
    word-break: keep-all;
  }

  .yb-shot-notice p + p {
    margin-top: 15px;
  }


  .yb-shot-footer {
    position: relative;
    z-index: 2;
    padding: 42px 0 118px;
    background:
      radial-gradient(circle at 18% 0%, rgba(31, 67, 142, 0.06), transparent 30%),
      #02050b;
    border-top: 1px solid rgba(255, 255, 255, 0.055);
  }

  .yb-shot-footer-inner {
    width: min(1120px, calc(100% - 44px));
    margin: 0 auto;
  }

  .yb-shot-footer-brand {
    margin: 0 0 22px;
    color: rgba(255, 255, 255, 0.94);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.55;
    letter-spacing: -0.04em;
  }

  .yb-shot-footer-brand span {
    color: rgba(255, 255, 255, 0.48);
    font-weight: 300;
  }

  .yb-shot-footer-info {
    display: grid;
    gap: 13px;
    margin: 0;
  }

  .yb-shot-footer-info p,
  .yb-shot-footer-copy {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 13px;
    font-weight: 300;
    line-height: 1.55;
    letter-spacing: -0.035em;
    word-break: keep-all;
  }

  .yb-shot-footer-info p strong {
    color: rgba(255, 255, 255, 0.7);
    font-weight: 400;
  }

  .yb-shot-footer-copy {
    margin-top: 30px;
    color: rgba(255, 255, 255, 0.46);
  }


  .yb-shot-reveal {
    opacity: 1;
    transition:
      transform 0.82s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.82s ease;
    will-change: transform, filter;
    filter: saturate(0.88);
  }

  .yb-shot-reveal.yb-slide-left {
    transform: translateX(-44px) scale(0.985);
  }

  .yb-shot-reveal.yb-slide-right {
    transform: translateX(44px) scale(0.985);
  }

  .yb-shot-reveal.is-visible {
    transform: translateX(0) scale(1);
    filter: saturate(1);
  }

  .yb-shot-fixed-actions {
    position: fixed;
    left: 50%;
    bottom: max(14px, env(safe-area-inset-bottom));
    z-index: 80;
    width: min(620px, calc(100% - 24px));
    padding: 10px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.11);
    background: rgba(3, 7, 15, 0.86);
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(18px);
    transform: translateX(-50%);
  }

  .yb-shot-fixed-action {
    position: relative;
    overflow: hidden;
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.045);
    color: rgba(255, 255, 255, 0.94);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.045em;
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
  }

  .yb-shot-fixed-action.primary {
    border-color: rgba(54, 111, 255, 0.58);
    background: linear-gradient(135deg, #2f6cff 0%, #2459d8 100%);
    box-shadow: 0 14px 30px rgba(47, 108, 255, 0.24);
  }

  .yb-shot-fixed-action:hover {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.075);
  }

  .yb-shot-fixed-action.primary:hover {
    background: linear-gradient(135deg, #3774ff 0%, #285fe5 100%);
  }


  @keyframes ybHeroRise {
    0% {
      transform: translateY(12px);
      filter: blur(4px);
    }

    100% {
      transform: translateY(-2vh);
      filter: blur(0);
    }
  }

  @keyframes ybLogoFloat {
    0%, 100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-7px);
    }
  }

  @keyframes ybSoftPulse {
    0%, 100% {
      transform: scale(0.98);
      opacity: 0.44;
    }

    50% {
      transform: scale(1.06);
      opacity: 0.88;
    }
  }

  @keyframes ybPanelDriftA {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(10px, -12px, 0); }
  }

  @keyframes ybPanelDriftB {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-12px, 10px, 0); }
  }

  @keyframes ybPanelDriftC {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .yb-shot-reveal,
    .yb-shot-reveal.yb-slide-left,
    .yb-shot-reveal.yb-slide-right,
    .yb-shot-logo-wrap,
    .yb-shot-logo-wrap::before,
    .yb-shot-panel-a,
    .yb-shot-panel-b,
    .yb-shot-panel-c,
    .yb-shot-hero-content {
      transform: none !important;
      transition: none !important;
      animation: none !important;
      filter: none !important;
    }
  }

  @media (max-width: 900px) {
    .yb-shot-grid-3,
    .yb-shot-proof-grid,
    .yb-shot-faq-grid {
      grid-template-columns: 1fr;
    }

    .yb-shot-split {
      grid-template-columns: 1fr;
    }
  }

