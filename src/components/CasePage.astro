---
import ConsultForm from './ConsultForm.astro';
import { cleanText } from '../lib/utils.js';

const { site = {}, row = {} } = Astro.props;
const keyword = cleanText(row.mainKeyword || row.caseName || row.slug || '금융사기');
const phone = site.phone || '010-2175-4252';
const telHref = site.telLink || `tel:${phone.replace(/\D/g, '')}`;
const kakao = site.kakaoUrl || 'https://open.kakao.com/o/sEEHGIti';
const risks = Array.isArray(row.risks) ? row.risks : [row.risk1, row.risk2, row.risk3].filter(Boolean);
const triggers = Array.isArray(row.triggers) ? row.triggers : [row.trigger1, row.trigger2, row.trigger3].filter(Boolean);
const steps = Array.isArray(row.processSteps) ? row.processSteps : ['피해 자료 확인', '대응 가능성 검토', '실행 절차 안내'];
const faqs = Array.isArray(row.faqs) ? row.faqs : [];
const themeClass = `case-theme-${site.theme || 'response'}`;
---

<article class={`case-shell ${themeClass}`} style={`--case-accent:${site.colors?.accent || '#4c7dff'};--case-accent2:${site.colors?.accent2 || '#9ab7ff'};--case-bg:${site.colors?.bg || '#06101f'};--case-surface:${site.colors?.surface || '#0b1b31'};--case-text:${site.colors?.text || '#f7f9ff'};`}>
  <section class="case-hero">
    <div class="case-grid"></div>
    <div class="case-orb case-orb-a"></div>
    <div class="case-orb case-orb-b"></div>
    <div class="case-container case-hero-inner">
      <a class="case-back" href="/">← 돌아가기</a>
      <div class="case-brand">
        <img src={site.logo || '/images/yoonbit-logo-cutout.png'} alt="법무법인 윤빛" loading="eager" />
        <span>{site.siteName}</span>
      </div>
      <p class="case-eyebrow">{row.eyebrow || site.content?.heroBadge}</p>
      <div class="case-badge"><i></i>{row.heroBadge}</div>
      <h1>{row.headline}</h1>
      <p class="case-lead">{row.subHeadline}</p>
      <div class="case-hero-actions">
        <a class="case-primary" href="#consult">피해 정황 확인하기</a>
        <a class="case-secondary" href={telHref}>{phone}</a>
      </div>
      <div class="case-notice"><strong>긴급 안내</strong><span>{row.noticeText}</span></div>
    </div>
  </section>

  <section class="case-proofbar">
    <div class="case-container case-proof-grid">
      <div><strong>01</strong><span>입금자료 기준 확인</span></div>
      <div><strong>02</strong><span>추가 피해 즉시 차단</span></div>
      <div><strong>03</strong><span>민·형사 절차 동시 검토</span></div>
      <div><strong>04</strong><span>상대방 특정 단서 보존</span></div>
    </div>
  </section>

  <section class="case-section case-risk-section">
    <div class="case-container">
      <header class="case-section-head">
        <p>CRITICAL CHECK</p>
        <h2>{row.sectionTitle}</h2>
        <span>{keyword} 관련 피해는 작은 단서 하나가 대응 방향을 바꿀 수 있습니다.</span>
      </header>
      <div class="case-card-grid">
        {risks.map((text, index) => (
          <article class="case-card">
            <div class="case-card-no">0{index + 1}</div>
            <h3>{['입금과 자금 흐름', '상대방 특정 자료', '대응 시점과 절차'][index] || '핵심 확인'}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="case-section case-alert-section">
    <div class="case-container case-split">
      <div class="case-copy">
        <p>WARNING SIGNAL</p>
        <h2>아래 정황이 있다면<br />더 기다리지 마세요</h2>
        <span>추가 송금이나 자료 삭제 전에 현재 상황을 먼저 확인해야 합니다.</span>
      </div>
      <div class="case-trigger-list">
        {triggers.map((text, index) => (
          <div class="case-trigger"><b>{String(index + 1).padStart(2, '0')}</b><span>{text}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="case-section case-fact-section">
    <div class="case-container">
      <div class="case-fact">
        <div class="case-fact-mark">FACT</div>
        <div>
          <p>CASE ANALYSIS</p>
          <h2>{row.factTitle}</h2>
          <span>{row.factBody}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="case-section case-process-section">
    <div class="case-container">
      <header class="case-section-head">
        <p>RESPONSE PROCESS</p>
        <h2>{row.processTitle}</h2>
        <span>형식적인 안내가 아니라 현재 자료와 피해 단계에 맞춰 순서를 정합니다.</span>
      </header>
      <div class="case-process-grid">
        {steps.map((step, index) => (
          <article>
            <i>STEP {String(index + 1).padStart(2, '0')}</i>
            <strong>{step}</strong>
            <p>{[
              '입금내역, 이체확인증, 계좌정보, 대화자료와 사이트 화면을 기준으로 피해 구조를 확인합니다.',
              '자금 이동 가능성, 상대방 특정 단서, 지급정지와 법적 조치 가능성을 함께 검토합니다.',
              '긴급도와 회수 가능성을 기준으로 지금 실행할 절차와 준비자료를 안내합니다.'
            ][index] || '사건 진행 단계에 맞춰 필요한 조치를 안내합니다.'}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="case-section case-evidence-section">
    <div class="case-container case-evidence-layout">
      <div class="case-copy">
        <p>EVIDENCE CHECKLIST</p>
        <h2>지금 삭제하면 안 되는<br />핵심 증거자료</h2>
        <span>자료가 완벽하지 않아도 남아 있는 것부터 보존해야 합니다.</span>
      </div>
      <div class="case-evidence-grid">
        {['입금내역·이체확인증', '카카오톡·텔레그램 대화', '사이트·앱 화면 캡처', '계좌번호·예금주·지갑주소', '담당자 전화번호·프로필', '추가 입금 요구 내용'].map((item, i) => (
          <div><b>{String(i + 1).padStart(2, '0')}</b><span>{item}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="case-section case-faq-section">
    <div class="case-container">
      <header class="case-section-head">
        <p>FREQUENTLY ASKED</p>
        <h2>{keyword} 피해 관련 자주 묻는 질문</h2>
      </header>
      <div class="case-faq-list">
        {faqs.map(([question, answer]) => (
          <details>
            <summary>{question}<span>＋</span></summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="case-consult" id="consult">
    <div class="case-container case-consult-layout">
      <div class="case-consult-copy">
        <p>24H CONSULTATION</p>
        <h2>지금 남아 있는 자료로<br />대응 가능성부터 확인하세요</h2>
        <span>접수 후 담당자가 피해 정황과 자료를 확인하여 순차적으로 연락드립니다.</span>
        <div class="case-contact-row">
          <a href={telHref}>전화 상담 {phone}</a>
          <a href={kakao} target="_blank" rel="noopener noreferrer">카카오 상담</a>
        </div>
      </div>
      <div class="case-form-wrap"><ConsultForm site={site} caseName={keyword} /></div>
    </div>
  </section>
</article>

<style>
  .case-shell{--line:rgba(255,255,255,.1);--muted:rgba(236,242,255,.66);background:var(--case-bg);color:var(--case-text);font-family:Pretendard,"Noto Sans KR",system-ui,sans-serif;overflow:hidden}.case-container{width:min(1160px,calc(100% - 40px));margin:0 auto}.case-hero{position:relative;min-height:920px;display:flex;align-items:center;padding:150px 0 110px;background:radial-gradient(circle at 50% 38%,color-mix(in srgb,var(--case-accent) 28%,transparent),transparent 38%),linear-gradient(180deg,color-mix(in srgb,var(--case-bg) 92%,#000),var(--case-bg));isolation:isolate}.case-grid{position:absolute;inset:0;opacity:.18;background-image:linear-gradient(rgba(255,255,255,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.08) 1px,transparent 1px);background-size:70px 70px;mask-image:linear-gradient(to bottom,black,transparent 85%)}.case-orb{position:absolute;border-radius:50%;filter:blur(1px);border:1px solid color-mix(in srgb,var(--case-accent2) 28%,transparent);box-shadow:inset 0 0 80px color-mix(in srgb,var(--case-accent) 12%,transparent)}.case-orb-a{width:420px;height:420px;right:-130px;top:170px}.case-orb-b{width:260px;height:260px;left:-80px;bottom:90px}.case-hero-inner{position:relative;z-index:2;text-align:center}.case-back{position:absolute;left:0;top:-85px;color:rgba(255,255,255,.62);font-size:13px}.case-brand{display:flex;justify-content:center;align-items:center;gap:16px;margin-bottom:38px}.case-brand img{width:148px;height:auto;filter:brightness(1.15)}.case-brand span{display:none}.case-eyebrow{margin:0 0 18px;color:var(--case-accent2);font-weight:800;letter-spacing:.24em;font-size:12px}.case-badge{display:inline-flex;align-items:center;gap:9px;padding:10px 15px;border:1px solid color-mix(in srgb,var(--case-accent) 36%,transparent);border-radius:999px;background:color-mix(in srgb,var(--case-accent) 10%,transparent);font-size:13px;color:#fff}.case-badge i{width:7px;height:7px;border-radius:50%;background:var(--case-accent);box-shadow:0 0 18px var(--case-accent)}.case-hero h1{max-width:980px;margin:28px auto 0;font-size:clamp(42px,6vw,76px);line-height:1.15;letter-spacing:-.065em;word-break:keep-all}.case-lead{max-width:790px;margin:28px auto 0;color:var(--muted);font-size:clamp(17px,2vw,21px);line-height:1.8;word-break:keep-all}.case-hero-actions{display:flex;justify-content:center;gap:12px;margin-top:38px}.case-hero-actions a{min-width:210px;min-height:56px;display:inline-flex;align-items:center;justify-content:center;border-radius:8px;font-weight:800;font-size:15px}.case-primary{background:var(--case-accent);color:#fff;box-shadow:0 20px 60px color-mix(in srgb,var(--case-accent) 28%,transparent)}.case-secondary{border:1px solid rgba(255,255,255,.2);background:rgba(2,6,13,.45);color:#fff}.case-notice{max-width:800px;margin:34px auto 0;padding:18px 22px;border:1px solid var(--line);background:rgba(255,255,255,.035);display:flex;gap:18px;align-items:flex-start;text-align:left}.case-notice strong{flex:0 0 auto;color:var(--case-accent2);font-size:13px}.case-notice span{color:var(--muted);font-size:14px;line-height:1.7}.case-proofbar{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(0,0,0,.2)}.case-proof-grid{display:grid;grid-template-columns:repeat(4,1fr)}.case-proof-grid div{padding:25px 22px;border-right:1px solid var(--line);display:flex;align-items:center;gap:15px}.case-proof-grid div:last-child{border-right:0}.case-proof-grid strong{color:var(--case-accent2);font-size:12px}.case-proof-grid span{font-size:14px;color:rgba(255,255,255,.8)}.case-section{padding:112px 0}.case-section-head{text-align:center;max-width:850px;margin:0 auto 54px}.case-section-head>p,.case-copy>p,.case-fact p,.case-consult-copy>p{margin:0 0 14px;color:var(--case-accent2);font-size:12px;font-weight:900;letter-spacing:.2em}.case-section-head h2,.case-copy h2,.case-fact h2,.case-consult-copy h2{margin:0;font-size:clamp(32px,4.6vw,54px);line-height:1.24;letter-spacing:-.055em;word-break:keep-all}.case-section-head>span,.case-copy>span,.case-fact span,.case-consult-copy>span{display:block;margin-top:18px;color:var(--muted);font-size:17px;line-height:1.8}.case-risk-section{background:linear-gradient(180deg,var(--case-bg),color-mix(in srgb,var(--case-surface) 74%,var(--case-bg)))}.case-card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.case-card{min-height:330px;padding:34px;border:1px solid var(--line);background:linear-gradient(145deg,rgba(255,255,255,.07),rgba(255,255,255,.018));position:relative;overflow:hidden}.case-card:after{content:"";position:absolute;width:180px;height:180px;border-radius:50%;right:-70px;bottom:-90px;background:radial-gradient(circle,color-mix(in srgb,var(--case-accent) 25%,transparent),transparent 70%)}.case-card-no{color:var(--case-accent2);font-size:13px;font-weight:900;margin-bottom:75px}.case-card h3{font-size:23px;margin:0 0 16px;letter-spacing:-.04em}.case-card p{margin:0;color:var(--muted);line-height:1.8;word-break:keep-all}.case-alert-section{background:color-mix(in srgb,var(--case-surface) 80%,#000)}.case-split,.case-evidence-layout,.case-consult-layout{display:grid;grid-template-columns:.9fr 1.1fr;gap:70px;align-items:center}.case-trigger-list{display:grid;gap:12px}.case-trigger{padding:24px 26px;border:1px solid var(--line);background:rgba(255,255,255,.035);display:grid;grid-template-columns:42px 1fr;gap:16px;align-items:start}.case-trigger b{color:var(--case-accent2);font-size:13px}.case-trigger span{color:rgba(255,255,255,.84);line-height:1.7}.case-fact-section{background:var(--case-bg)}.case-fact{padding:58px;border:1px solid color-mix(in srgb,var(--case-accent) 28%,transparent);background:radial-gradient(circle at 10% 50%,color-mix(in srgb,var(--case-accent) 18%,transparent),transparent 30%),rgba(255,255,255,.025);display:grid;grid-template-columns:170px 1fr;gap:48px;align-items:center}.case-fact-mark{font-size:52px;font-weight:900;letter-spacing:-.08em;color:transparent;-webkit-text-stroke:1px color-mix(in srgb,var(--case-accent2) 55%,transparent)}.case-process-section{background:linear-gradient(180deg,color-mix(in srgb,var(--case-surface) 82%,#000),var(--case-bg))}.case-process-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}.case-process-grid article{min-height:315px;background:color-mix(in srgb,var(--case-bg) 80%,var(--case-surface));padding:36px}.case-process-grid i{font-style:normal;color:var(--case-accent2);font-size:12px;font-weight:800}.case-process-grid strong{display:block;margin:64px 0 16px;font-size:24px}.case-process-grid p{margin:0;color:var(--muted);line-height:1.75}.case-evidence-section{background:var(--case-bg)}.case-evidence-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.case-evidence-grid div{min-height:86px;padding:20px;border:1px solid var(--line);background:rgba(255,255,255,.03);display:flex;align-items:center;gap:18px}.case-evidence-grid b{color:var(--case-accent2);font-size:12px}.case-evidence-grid span{color:rgba(255,255,255,.84)}.case-faq-section{background:color-mix(in srgb,var(--case-surface) 72%,#000)}.case-faq-list{max-width:920px;margin:0 auto;display:grid;gap:10px}.case-faq-list details{border:1px solid var(--line);background:rgba(255,255,255,.025)}.case-faq-list summary{list-style:none;cursor:pointer;padding:24px 26px;display:flex;justify-content:space-between;gap:20px;font-weight:750}.case-faq-list summary::-webkit-details-marker{display:none}.case-faq-list summary span{color:var(--case-accent2)}.case-faq-list details p{margin:0;padding:0 26px 25px;color:var(--muted);line-height:1.8}.case-consult{padding:120px 0;background:radial-gradient(circle at 20% 50%,color-mix(in srgb,var(--case-accent) 24%,transparent),transparent 35%),linear-gradient(135deg,#02050a,color-mix(in srgb,var(--case-bg) 78%,#000))}.case-contact-row{display:flex;gap:10px;margin-top:30px}.case-contact-row a{display:inline-flex;min-height:48px;align-items:center;padding:0 18px;border:1px solid var(--line);color:#fff;border-radius:6px}.case-form-wrap{padding:34px;border:1px solid var(--line);background:rgba(2,6,14,.64);box-shadow:0 35px 100px rgba(0,0,0,.34)}
  .case-theme-check{--muted:rgba(226,242,239,.7)}
  @media(max-width:900px){.case-hero{min-height:auto;padding:130px 0 85px}.case-back{top:-70px}.case-proof-grid{grid-template-columns:1fr 1fr}.case-proof-grid div:nth-child(2){border-right:0}.case-card-grid,.case-process-grid{grid-template-columns:1fr}.case-split,.case-evidence-layout,.case-consult-layout{grid-template-columns:1fr;gap:42px}.case-fact{grid-template-columns:1fr}.case-fact-mark{font-size:38px}.case-section{padding:82px 0}.case-card{min-height:auto}.case-card-no{margin-bottom:40px}}
  @media(max-width:560px){.case-container{width:min(100% - 28px,1160px)}.case-brand img{width:128px}.case-hero h1{font-size:40px}.case-hero-actions{flex-direction:column}.case-hero-actions a{width:100%}.case-notice{display:block}.case-notice strong{display:block;margin-bottom:8px}.case-proof-grid{grid-template-columns:1fr}.case-proof-grid div{border-right:0;border-bottom:1px solid var(--line)}.case-card,.case-process-grid article,.case-fact,.case-form-wrap{padding:24px}.case-evidence-grid{grid-template-columns:1fr}.case-contact-row{flex-direction:column}.case-section-head h2,.case-copy h2,.case-fact h2,.case-consult-copy h2{font-size:34px}}
</style>
