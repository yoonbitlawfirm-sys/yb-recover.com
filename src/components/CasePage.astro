      font-size: clamp(28px, 8.2vw, 38px);
      line-height: 1.3;
    }

    .yb-shot-head span,
    .yb-shot-copy span {
      margin-top: 16px;
      font-size: 14px;
      line-height: 1.72;
    }

    .yb-shot-card,
    .yb-shot-mini {
      min-height: auto;
      padding: 24px 22px;
      border-radius: 18px;
    }

    .yb-shot-card strong,
    .yb-shot-mini strong {
      font-size: 20px;
    }

    .yb-shot-consult {
      padding: 18px;
      border-radius: 18px;
    }

    .yb-shot-consult-after {
      margin-top: 12px;
      padding: 13px 12px;
      font-size: 12px;
    }

    .yb-shot-live {
      padding: 17px;
      border-radius: 20px;
    }

    .yb-shot-live-head {
      margin-bottom: 12px;
      padding-bottom: 13px;
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .yb-shot-live-title h3 {
      font-size: 19px;
    }

    .yb-shot-live-viewport {
      height: 392px;
