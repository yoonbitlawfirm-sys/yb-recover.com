---
import ConsultForm from './ConsultForm.astro';
import { cleanText } from '../lib/utils.js';

const { site = {}, row = {} } = Astro.props;

const name = cleanText(row.caseName || row.mainKeyword || row.slug || '금융사기');

const theme = site?.theme || 'main';

const kakao = site?.kakao || 'https://open.kakao.com/o/s9AiNHzi';
const phone = site?.phone || '010-2175-4252';
const tel = site?.tel || phone.replace(/\D/g, '');
const telHref = `tel:${tel}`;
const logo = site?.logo || '/images/yoonbit-logo-cutout.png';

const recoveryChecks = [
  [
    '01',
    '입금 흐름 확인',
    '입금 계좌, 예금주, 지갑주소, 송금 시점과 명목을 먼저 정리합니다. 대포통장을 거쳐 자금이 분산되기 전, 자금 흐름을 잡는 것이 회수 가능성 검토의 출발점입니다.'
  ],
  [
    '02',
    '상대방 특정 단서',
    '담당자 이름, 연락처, 대화방, 사이트 주소, 입금 계좌, 예금주 등 상대방을 특정할 단서가 남아 있는지 확인합니다. 단서가 사라지기 전 보존하는 것이 중요합니다.'
  ],
  [
    '03',
    '법적 대응 가능성',
    '자금 추적, 지급정지, 고소, 가압류, 손해배상, 합의 가능성을 함께 검토합니다. 단순 신고에 그치지 않고 원금 회수 가능성을 높이는 방향으로 대응합니다.'
  ]
];

const warningCards = [
  [
    '01',
    '출금 지연',
    '출금 신청 후 처리 중이라는 답변만 반복되거나 승인 시간이 계속 미뤄지는 경우입니다. 이 단계에서 계좌·사이트 단서가 사라지기 전 자료 보존이 필요합니다.'
  ],
  [
    '02',
    '추가 입금 요구',
    '세금, 인증비, 보증금, 수수료, 계좌검증비 등의 명목으로 추가 송금을 요구받는 경우입니다. 추가 입금 전 피해 정황부터 확인해야 합니다.'
  ],
  [
    '03',
    '연락두절',
    '담당자 답변이 늦어지거나 대화방이 사라지고 사이트 접속이 제한되는 경우입니다. 연락두절 전후의 자료가 대응 방향을 좌우할 수 있습니다.'
  ]
];

const proofCards = [
  [
    '01',
    '자료 기준 검토',
    '입금내역, 대화자료, 사이트 화면, 계좌정보를 기준으로 현재 피해 유형과 대응 우선순위를 정리합니다.'
  ],
  [
    '02',
    '민·형사 절차 검토',
    '상대방 특정 가능성과 자금 이동 흐름을 기준으로 형사 고소, 지급정지, 가압류, 손해배상 가능성을 함께 확인합니다.'
  ],
  [
    '03',
    '회수 가능성 판단',
    '대포통장을 통한 자금세탁 가능성과 남아 있는 증거를 기준으로 회수 가능성을 높일 대응 방향을 검토합니다.'
  ]
];

const faqs = [
  [
    '이미 입금한 돈을 돌려받을 수 있나요?',
    `회수 가능성은 입금 계좌, 자금 이동 속도, 상대방 특정 가능성, 증거자료 상태에 따라 달라집니다. 윤빛은 ${name} 관련 남아 있는 자료를 기준으로 지급정지·고소·가압류·손해배상 등 대응 가능성부터 확인합니다.`
  ],
  [
    '경찰 신고만 하면 원금이 돌아오나요?',
    '경찰 신고는 수사의 출발점입니다. 원금 회수 가능성을 높이려면 입금 흐름, 대포통장 여부, 상대방 특정 단서, 민·형사 절차 가능성을 함께 검토해야 합니다.'
  ],
  [
    '추가 입금을 하면 출금이 가능하다고 합니다.',
    '세금, 인증비, 보증금, 계좌검증비 명목의 추가 입금 요구는 위험 신호일 수 있습니다. 추가 송금 전 현재 정황과 자료 상태를 먼저 확인해야 합니다.'
  ],
  [
    '자료가 부족해도 상담 가능한가요?',
    '가능합니다. 입금내역, 대화자료, 사이트 화면, 계좌정보 중 일부만 있어도 피해 정황을 정리하고 우선 대응 방향을 검토할 수 있습니다.'
  ]
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer
    }
  }))
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${name} 피해 의심 시 대응 가능성 확인 방법`,
  description: `${name} 피해가 의심될 때 입금내역, 대화자료, 계좌정보를 기준으로 대응 가능성을 확인하는 절차입니다.`,
  totalTime: 'PT5M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: '입금자료 보존',
      text: '입금내역, 이체확인증, 계좌번호, 예금주, 지갑주소 등 자금 이동 경로를 확인할 자료를 보존합니다.'
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: '대화자료 저장',
      text: '카카오톡, 텔레그램, 문자, 사이트 상담창, 추가 입금 요구 내용을 삭제하지 않고 캡처합니다.'
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: '법적 조치 검토',
      text: '지급정지, 고소, 가압류, 손해배상, 합의 가능성을 함께 검토해 대응 방향을 정리합니다.'
    }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${name} 사칭 사기 주의 | 법무법인 윤빛`,
  description: `${name} 관련 입금을 하신 상황이라면 출금 지연, 추가 입금 요구, 연락두절 정황을 기준으로 빠른 법적 대응 가능성을 확인합니다.`,
  inLanguage: 'ko-KR',
  about: {
    '@type': 'Thing',
    name: `${name} 피해 정황 및 대응 가능성`
  }
};
---

<style is:global>
  header,
  nav,
  .site-header,
  .yb-header,
  .global-header,
  .main-header,
  .top-header,
  .navbar,
  .gnb,
  .header,
  .header-wrap,
  .nav-wrap,
  .navigation,
  .desktop-nav,
  .mobile-nav,
  .top-floating,
  .top-fixed,
  .fixed-top,
  .floating-top,
  .reservation-bar,
  .consult-reserve,
  .reserve-button,
  .bottom-floating,
  .floating-cta,
  .bottom-cta,
  .sticky-cta,
  .fixed-cta,
  .mobile-cta,
  .consult-floating,
  .floating-consult,
  .quick-consult,
  .quick-cta,
  .cta-fixed,
  .fixed-bottom,
  .bottom-bar,
  .floating-bar,
  .contact-floating,
  .floating-bottom,
  .bottom-consult,
  .consult-bar,
  .sticky-bottom,
  .floating-call,
  .call-floating,
  .fixed-consult-bar,
  .floating-actions,
  .fixed-actions,
  .fixed-contact,
  .floating-contact,
  .bottom-buttons,
  .bottom-button-wrap,
  .bottom-action-bar,
  .bottom-fixed-cta,
  .mobile-bottom-fixed,
  .mobile-bottom-cta,
  .mobile-fixed-bottom,
  .quick-buttons,
  .quick-action-buttons,
  .call-kakao-floating,
  .call-kakao-bar,
  .contact-actions,
  .contact-action-bar,
  .tel-kakao-bar,
  .phone-kakao-bar {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  footer:not(.yb-shot-footer),
  .site-footer,
  .global-footer,
  .main-footer,
  .footer,
  .footer-wrap,
  .copyright,
  .page-footer {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  html,
  body {
    margin: 0 !important;
    padding: 0 !important;
    overflow-x: hidden;
    background: #02050b;
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
  }
</style>

<style>
  .yb-shot-page {
    min-height: 100vh;
    background: #02050b;
    color: #ffffff;
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
    overflow-x: hidden;
    padding-bottom: 92px;
  }

  .yb-shot-page * {
    box-sizing: border-box;
  }

  .yb-shot-back {
    position: absolute;
    top: 22px;
    left: 22px;
    z-index: 50;
    height: 42px;
    padding: 0 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(4, 8, 16, 0.62);
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 13px;
    font-weight: 300;
    letter-spacing: -0.035em;
    backdrop-filter: blur(14px);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.24);
  }

  .yb-shot-back svg {
    width: 16px;
    height: 16px;
  }

  .yb-shot-inner {
    width: min(1120px, calc(100% - 44px));
    margin: 0 auto;
  }

  .yb-shot-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(circle at 72% 68%, rgba(31, 67, 142, 0.055), transparent 34%),
      linear-gradient(135deg, #02050b 0%, #040914 42%, #07101d 72%, #02050b 100%);
  }

  .yb-shot-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.78), transparent 31%, transparent 69%, rgba(0, 0, 0, 0.68)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.48));
    pointer-events: none;
  }

  .yb-shot-hero::after,
  .yb-shot-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.014) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
    background-size: 84px 84px;
    opacity: 0.34;
    pointer-events: none;
  }

  .yb-shot-panel-a,
  .yb-shot-panel-b,
  .yb-shot-panel-c {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .yb-shot-panel-a {
    left: 0;
    top: 24%;
    width: 22vw;
    height: 45vh;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.004)),
      linear-gradient(180deg, rgba(8, 15, 31, 0.82), rgba(4, 8, 16, 0.96));
    border: 1px solid rgba(255, 255, 255, 0.035);
    animation: ybPanelDriftA 9s ease-in-out infinite;
  }

  .yb-shot-panel-b {
    right: 0;
    top: 22%;
    width: 24vw;
    height: 38vh;
    background:
      radial-gradient(circle at 50% 40%, rgba(31, 67, 142, 0.12), transparent 45%),
      linear-gradient(180deg, rgba(8, 20, 47, 0.9), rgba(5, 10, 20, 0.94));
    border: 1px solid rgba(255, 255, 255, 0.035);
    animation: ybPanelDriftB 10s ease-in-out infinite;
  }

  .yb-shot-panel-c {
    left: 34%;
    bottom: 0;
    width: 32vw;
    height: 24vh;
    background:
      radial-gradient(circle at 50% 44%, rgba(31, 67, 142, 0.08), transparent 48%),
      linear-gradient(180deg, rgba(10, 22, 46, 0.72), rgba(4, 8, 16, 0.98));
    border: 1px solid rgba(255, 255, 255, 0.035);
    animation: ybPanelDriftC 11s ease-in-out infinite;
  }

  .yb-shot-hero-content {
    position: relative;
    z-index: 3;
    width: min(720px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
    transform: translateY(-2vh);
    animation: ybHeroRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .yb-shot-logo-wrap {
    position: relative;
    width: 176px;
    height: 176px;
    margin: 0 auto 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(4, 8, 16, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.095);
    box-shadow:
      0 26px 62px rgba(0, 0, 0, 0.36),
      0 0 0 1px rgba(201, 164, 92, 0.055),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
    backdrop-filter: blur(16px);
    animation: ybLogoFloat 5.8s ease-in-out infinite;
  }

  .yb-shot-logo-wrap::before {
    content: "";
    position: absolute;
    inset: -15px;
    border-radius: 50%;
    border: 1px solid rgba(201, 164, 92, 0.16);
    background: radial-gradient(circle, rgba(201, 164, 92, 0.075), transparent 62%);
    opacity: 0.72;
    animation: ybSoftPulse 3.8s ease-in-out infinite;
  }

  .yb-shot-logo-wrap::after {
    content: "";
    position: absolute;
    inset: 17px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }

  .yb-shot-logo {
    position: relative;
    z-index: 1;
    width: 158px;
    height: 158px;
    max-width: 158px;
    max-height: 158px;
    object-fit: contain;
    opacity: 0.98;
    transform: scale(1.62);
    transform-origin: center;
    filter: drop-shadow(0 14px 24px rgba(0, 0, 0, 0.42));
  }

  .yb-shot-kicker {
    margin: 0 0 18px;
    color: rgba(201, 164, 92, 0.82);
    font-size: clamp(13px, 1.62vw, 16px);
    font-weight: 500;
    letter-spacing: 0.26em;
    line-height: 1.45;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-hero h1,
  .yb-shot-head h2,
  .yb-shot-copy h2 {
    margin: 0;
    color: rgba(255, 255, 255, 0.96);
    font-weight: 500;
    letter-spacing: -0.065em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-hero h1 {
    font-size: clamp(38px, 5.8vw, 62px);
    line-height: 1.12;
  }

  .yb-shot-hero h1 .yb-shot-title-line {
    display: block;
    white-space: nowrap;
  }

  .yb-shot-hero-copy {
    width: min(92vw, 620px);
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: clamp(15px, 1.7vw, 18px);
    font-weight: 300;
    line-height: 1.75;
    letter-spacing: -0.035em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-hero-actions {
    width: min(520px, 100%);
    margin: 34px auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .yb-shot-action {
    position: relative;
    overflow: hidden;
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.13);
    color: rgba(255, 255, 255, 0.86);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -0.035em;
    text-decoration: none;
    background: rgba(4, 8, 16, 0.66);
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(16px);
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease;
  }

  .yb-shot-action::before,
  .yb-shot-fixed-action::before {
    content: "";
    position: absolute;
    top: 0;
    left: -75%;
    width: 48%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.14), transparent);
    transform: skewX(-18deg);
    transition: left 0.62s ease;
    pointer-events: none;
  }

  .yb-shot-action:hover::before,
  .yb-shot-fixed-action:hover::before {
    left: 125%;
  }

  .yb-shot-action:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 20px 54px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
  }

  .yb-shot-action.primary {
    border-color: rgba(166, 28, 39, 0.42);
    background: rgba(166, 28, 39, 0.88);
    color: #ffffff;
    box-shadow: 0 14px 34px rgba(139, 18, 28, 0.28);
  }

  .yb-shot-section {
    position: relative;
    padding: 92px 0;
    background:
      radial-gradient(circle at 82% 12%, rgba(31, 67, 142, 0.055), transparent 34%),
      linear-gradient(180deg, #02050b 0%, #050914 100%);
    overflow: hidden;
  }

  .yb-shot-section.alt {
    background:
      radial-gradient(circle at 12% 10%, rgba(201, 164, 92, 0.038), transparent 32%),
      linear-gradient(180deg, #050914 0%, #02050b 100%);
  }

  .yb-shot-head {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: 36px;
  }

  .yb-shot-head p,
  .yb-shot-copy p {
    margin: 0 0 14px;
    color: rgba(201, 164, 92, 0.82);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-align: center;
  }

  .yb-shot-head h2,
  .yb-shot-copy h2 {
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1.26;
  }

  .yb-shot-head span,
  .yb-shot-copy span {
    display: block;
    width: min(100%, 680px);
    margin: 18px auto 0;
    color: rgba(255, 255, 255, 0.64);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.78;
    letter-spacing: -0.035em;
    word-break: keep-all;
    text-align: center;
  }

  .yb-shot-grid-3,
  .yb-shot-proof-grid,
  .yb-shot-faq-grid {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 14px;
  }

  .yb-shot-grid-3,
  .yb-shot-proof-grid {
    grid-template-columns: repeat(3, 1fr);
  }

