<script is:inline>
  const LIVE_NAMES = [
    '김○○', '이○○', '박○○', '최○○', '정○○', '강○○', '조○○', '윤○○', '장○○', '임○○',
    '한○○', '오○○', '서○○', '신○○', '권○○', '황○○', '안○○', '송○○', '류○○', '홍○○',
    '문○○', '양○○', '고○○', '백○○', '남○○', '유○○', '전○○', '하○○', '구○○', '민○○'
  ];

  const LIVE_TIMES = [
    '12분 전', '19분 전', '27분 전', '34분 전', '42분 전', '51분 전', '1시간 전', '1시간 전', '2시간 전', '2시간 전',
    '3시간 전', '3시간 전', '4시간 전', '5시간 전', '5시간 전', '6시간 전', '7시간 전', '8시간 전', '9시간 전', '10시간 전',
    '11시간 전', '12시간 전', '13시간 전', '14시간 전', '15시간 전', '16시간 전', '18시간 전', '20시간 전', '22시간 전', '1일 전'
  ];

  const hashString = (value) => {
    let hash = 2166136261;

    for (let i = 0; i < value.length; i += 1) {
      hash ^= value.charCodeAt(i);
      hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
    }

    return Math.abs(hash >>> 0);
  };

  const seededRandom = (seed) => {
    let value = seed || 123456789;

    return () => {
      value = (value * 1664525 + 1013904223) >>> 0;
      return value / 4294967296;
    };
  };

  const getVisitorSeed = () => {
    const key = 'yb_recover_visitor_seed';

    try {
      let stored = localStorage.getItem(key);

      if (!stored) {
        stored = `${Date.now()}_${Math.random()}_${navigator.userAgent}`;
        localStorage.setItem(key, stored);
      }

      return hashString(stored);
    } catch (_) {
      return hashString(navigator.userAgent || 'yb-recover');
    }
  };

  const shuffle = (list, random) => {
    const copied = [...list];

    for (let i = copied.length - 1; i > 0; i -= 1) {
      const j = Math.floor(random() * (i + 1));
      [copied[i], copied[j]] = [copied[j], copied[i]];
    }

    return copied;
  };

  const renderLiveItems = () => {
    const target = document.getElementById('ybShotLiveList');
    if (!target) return;

    const random = seededRandom(getVisitorSeed());
    const names = shuffle(LIVE_NAMES, random);

    const items = Array.from({ length: 30 }).map((_, index) => ({
      text: `${names[index]}님의 상담신청이 접수되었습니다`,
      time: LIVE_TIMES[index]
    }));

    const html = items
      .map((item) => `
        <li class="yb-shot-live-item">
          <strong class="yb-shot-live-title-text">${item.text}</strong>
          <span class="yb-shot-live-time">${item.time}</span>
        </li>
      `)
      .join('');

    target.innerHTML = html + html;
  };

  const initMobileLiveScroll = () => {
    const list = document.getElementById('ybShotLiveList');
    const viewport = list?.closest('.yb-shot-live-viewport');

    if (!list || !viewport) return;
    if (!window.matchMedia('(max-width: 768px)').matches) return;
    if (window.__ybShotMobileLiveScrollStarted) return;

    window.__ybShotMobileLiveScrollStarted = true;
    list.style.animation = 'none';
    list.style.willChange = 'transform';

    let baseHeight = Math.max(1, list.scrollHeight / 2);
    let y = 0;
    let lastTime = performance.now();
    const speed = 0.026;

    const tick = (now) => {
      baseHeight = Math.max(1, list.scrollHeight / 2);
      const delta = Math.min(80, now - lastTime);
      lastTime = now;
      y = (y + delta * speed) % baseHeight;
      list.style.transform = `translate3d(0, -${y}px, 0)`;
      requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };





  const removeConsultFormInternalNotice = () => {
    const targetPhrase = '접수 후 담당자가 순차적으로 확인합니다';

    document.querySelectorAll('.yb-shot-consult p, .yb-shot-consult small, .yb-shot-consult span, .yb-shot-consult div').forEach((element) => {
      if (element.closest('.yb-shot-consult-after')) return;

      const text = (element.textContent || '').replace(/\s+/g, ' ').trim();
      if (!text.includes(targetPhrase)) return;

      const hasField = element.querySelector('input, textarea, select, button, form');
      if (hasField) return;

      element.remove();
    });
  };

  const cleanupLegacyFloatingBars = () => {
    const hideLegacy = (element) => {
      if (!element || element.closest('.yb-shot-fixed-actions')) return;
      if (element === document.body || element === document.documentElement) return;

      element.setAttribute('aria-hidden', 'true');
      element.style.setProperty('display', 'none', 'important');
      element.style.setProperty('visibility', 'hidden', 'important');
      element.style.setProperty('opacity', '0', 'important');
      element.style.setProperty('height', '0', 'important');
      element.style.setProperty('min-height', '0', 'important');
      element.style.setProperty('max-height', '0', 'important');
      element.style.setProperty('overflow', 'hidden', 'important');
      element.style.setProperty('pointer-events', 'none', 'important');
    };

    const isBottomFloating = (element) => {
      if (!element || element.closest('.yb-shot-fixed-actions')) return false;

      const style = window.getComputedStyle(element);
      const rect = element.getBoundingClientRect();
      const isFixedLike = style.position === 'fixed' || style.position === 'sticky';
      const isBottomArea = rect.bottom >= window.innerHeight - 140 && rect.top >= window.innerHeight * 0.42;
      const isBarSize = rect.width >= Math.min(260, window.innerWidth * 0.55) && rect.height <= 180;

      return isFixedLike && isBottomArea && isBarSize;
    };

    document.querySelectorAll('div, nav, section, aside').forEach((element) => {
      if (!isBottomFloating(element)) return;

      const text = (element.textContent || '').replace(/\s+/g, '');
      const hasOldTwoButtonText = text.includes('전화상담') && text.includes('카카오상담') && !text.includes('상담신청');
      const hasOldActionLinks = element.querySelector('a[href^="tel:"], a[href*="open.kakao.com"]') && text.includes('카카오');

      if (hasOldTwoButtonText || hasOldActionLinks) {
        hideLegacy(element);
      }
    });

    document.querySelectorAll('a, button').forEach((trigger) => {
      if (trigger.closest('.yb-shot-fixed-actions')) return;

      const text = (trigger.textContent || '').replace(/\s+/g, '');
      const href = trigger.getAttribute('href') || '';
      const looksLikeOldButton = text === '전화상담' || text === '카카오상담' || href.startsWith('tel:') || href.includes('open.kakao.com');
      if (!looksLikeOldButton) return;

      let current = trigger.parentElement;
      let depth = 0;

      while (current && current !== document.body && depth < 7) {
        if (current.closest('.yb-shot-fixed-actions')) return;

        const currentText = (current.textContent || '').replace(/\s+/g, '');
        if (isBottomFloating(current) && currentText.includes('전화상담') && currentText.includes('카카오상담') && !currentText.includes('상담신청')) {
          hideLegacy(current);
          return;
        }

        current = current.parentElement;
        depth += 1;
      }
    });
  };

  const initReveal = () => {
    const targets = document.querySelectorAll(
      '.yb-shot-section, .yb-shot-card, .yb-shot-mini, .yb-shot-consult, .yb-shot-live, .yb-shot-faq, .yb-shot-notice, .yb-shot-footer'
    );

    targets.forEach((target, index) => {
      target.classList.add('yb-shot-reveal', index % 2 === 0 ? 'yb-slide-left' : 'yb-slide-right');
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -70px 0px' }
    );

    targets.forEach((target) => observer.observe(target));
  };

  cleanupLegacyFloatingBars();
  removeConsultFormInternalNotice();
  renderLiveItems();
  initMobileLiveScroll();
  initReveal();

  window.addEventListener('load', () => {
    cleanupLegacyFloatingBars();
    removeConsultFormInternalNotice();
    initMobileLiveScroll();
  });
  window.addEventListener('resize', cleanupLegacyFloatingBars);
  setTimeout(() => {
    cleanupLegacyFloatingBars();
    removeConsultFormInternalNotice();
  }, 250);
  setTimeout(() => {
    cleanupLegacyFloatingBars();
    removeConsultFormInternalNotice();
  }, 900);
  setTimeout(() => {
    cleanupLegacyFloatingBars();
    removeConsultFormInternalNotice();
  }, 1800);

  const consultNoticeObserverTarget = document.querySelector('.yb-shot-consult');
  if (consultNoticeObserverTarget) {
    const consultNoticeObserver = new MutationObserver(() => removeConsultFormInternalNotice());
    consultNoticeObserver.observe(consultNoticeObserverTarget, { childList: true, subtree: true });
  }


</script>

