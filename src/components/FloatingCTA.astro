---
const {
  site = {},
  phone = site?.phone || '010-2175-4252',
  phoneHref = site?.telLink || 'tel:01021754252',
  kakaoHref = site?.kakaoUrl || 'https://open.kakao.com/o/sEEHGIti',
  formHref = '#consult'
} = Astro.props;
---

<aside class="yb-detail-floating" aria-label="빠른 상담 메뉴" data-detail-floating>
  <div class="yb-detail-floating__inner">
    <a class="yb-detail-floating__item yb-detail-floating__item--phone" href={phoneHref} aria-label={`${phone} 전화 상담`}>
      <span class="yb-detail-floating__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false"><path d="M6.62 10.79a15.46 15.46 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z" /></svg>
      </span>
      <span class="yb-detail-floating__copy">
        <small>{phone}</small>
        <strong>전화 상담</strong>
      </span>
    </a>

    <a class="yb-detail-floating__item yb-detail-floating__item--kakao" href={kakaoHref} target="_blank" rel="noopener noreferrer" aria-label="카카오톡 상담">
      <span class="yb-detail-floating__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false"><path d="M12 3C6.48 3 2 6.58 2 11c0 2.82 1.82 5.29 4.56 6.72L5.4 22l4.91-2.88c.55.08 1.12.12 1.69.12 5.52 0 10-3.58 10-8.24S17.52 3 12 3Z" /></svg>
      </span>
      <span class="yb-detail-floating__copy">
        <small>실시간 문의</small>
        <strong>카카오 상담</strong>
      </span>
    </a>

    <a class="yb-detail-floating__item yb-detail-floating__item--form" href={formHref} aria-label="상담 신청서로 이동">
      <span class="yb-detail-floating__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false"><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm2 5h10V6H7v2Zm0 5h10v-2H7v2Zm0 5h6v-2H7v2Z" /></svg>
      </span>
      <span class="yb-detail-floating__copy">
        <small>24시간 접수</small>
        <strong>상담 신청</strong>
      </span>
    </a>
  </div>
</aside>

<style is:global>
  html:has(.yb-detail-floating) {
    scroll-padding-bottom: 104px;
  }

  body:has(.yb-detail-floating) {
    padding-bottom: max(88px, calc(76px + env(safe-area-inset-bottom)));
  }
</style>

<style>
  .yb-detail-floating {
    position: fixed;
    z-index: 2147483000;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    padding: 9px max(10px, env(safe-area-inset-right)) max(9px, env(safe-area-inset-bottom)) max(10px, env(safe-area-inset-left));
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(2, 5, 11, 0.93);
    box-shadow: 0 -18px 46px rgba(0, 0, 0, 0.38);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
  }

  .yb-detail-floating__inner {
    width: min(100%, 760px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 7px;
  }

  .yb-detail-floating__item {
    min-width: 0;
    min-height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 8px 10px;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 11px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.035));
    color: #fff;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: transform 160ms ease, filter 160ms ease, border-color 160ms ease;
  }

  .yb-detail-floating__item--phone {
    border-color: var(--yb-line);
    background: linear-gradient(135deg, var(--yb-surface-strong), var(--yb-surface));
  }

  .yb-detail-floating__item--kakao {
    border-color: #fee500;
    background: #fee500;
    color: #181600;
  }

  .yb-detail-floating__item--form {
    border-color: var(--yb-accent-2);
    background: linear-gradient(135deg, var(--yb-accent), var(--yb-accent-strong));
    color: var(--yb-on-accent);
    box-shadow: 0 12px 28px var(--yb-accent-soft);
  }

  .yb-detail-floating__item:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .yb-detail-floating__item:active {
    transform: scale(0.985);
  }

  .yb-detail-floating__item:focus-visible {
    outline: 3px solid var(--yb-accent-2);
    outline-offset: 2px;
  }

  .yb-detail-floating__icon {
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
    display: grid;
    place-items: center;
    color: currentColor;
  }

  .yb-detail-floating__icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .yb-detail-floating__copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .yb-detail-floating__copy small {
    display: block;
    max-width: 100%;
    color: currentColor;
    font-size: 9px;
    font-weight: 650;
    line-height: 1.1;
    opacity: 0.76;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .yb-detail-floating__copy strong {
    display: block;
    color: currentColor;
    font-size: 14px;
    font-weight: 850;
    line-height: 1.15;
    letter-spacing: -0.035em;
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .yb-detail-floating {
      padding-top: 7px;
      padding-right: 7px;
      padding-bottom: max(7px, env(safe-area-inset-bottom));
      padding-left: 7px;
    }

    .yb-detail-floating__inner {
      gap: 4px;
    }

    .yb-detail-floating__item {
      min-height: 57px;
      gap: 5px;
      padding: 6px 4px;
      border-radius: 9px;
    }

    .yb-detail-floating__icon {
      width: 18px;
      height: 18px;
      flex-basis: 18px;
    }

    .yb-detail-floating__copy small {
      font-size: 8px;
    }

    .yb-detail-floating__copy strong {
      font-size: clamp(11px, 3.3vw, 13px);
    }
  }

  @media (max-width: 360px) {
    .yb-detail-floating__item {
      flex-direction: column;
      gap: 2px;
    }

    .yb-detail-floating__copy {
      align-items: center;
    }
  }
</style>
