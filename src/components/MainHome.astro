---
import ConsultForm from './ConsultForm.astro';
import Footer from './Footer.astro';

const { site = {} } = Astro.props;
const launcher = site.launcher || {};
---

<main class="yb-launcher">
  <section class="yb-launcher-hero" aria-labelledby="yb-launcher-title">
    <div class="yb-shared-background" aria-hidden="true">
      <div class="yb-shared-background__panel yb-shared-background__panel--left"></div>
      <div class="yb-shared-background__panel yb-shared-background__panel--right"></div>
      <div class="yb-shared-background__panel yb-shared-background__panel--bottom"></div>
      <div class="yb-shared-background__grid"></div>
      <div class="yb-shared-background__glow"></div>
    </div>

    <div class="yb-launcher-hero__content">
      <p class="yb-launcher-hero__eyebrow">{launcher.eyebrow || site.shortName}</p>
      <h1 id="yb-launcher-title">{launcher.headline || '법무법인 윤빛'}</h1>
      <p class="yb-launcher-hero__subtitle">{launcher.subtitle || site.description}</p>

      <form class="yb-launcher-search" id="ybLauncherSearch" action="/scam" method="get" aria-label="피해 키워드 검색" novalidate>
        <label class="sr-only" for="ybLauncherInput">업체명 또는 피해 키워드</label>
        <input
          id="ybLauncherInput"
          name="keyword"
          type="search"
          placeholder={launcher.placeholder || '업체명 또는 피해 키워드를 입력하세요'}
          autocomplete="off"
          enterkeyhint="search"
          maxlength="80"
        />
        <button type="submit" aria-label="키워드 조회">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m20 20-3.5-3.5"></path>
          </svg>
          <span>조회</span>
        </button>
      </form>

      <p class="yb-launcher-hero__guide">{launcher.guide || '입력한 키워드의 피해 대응 안내 페이지로 이동합니다.'}</p>
    </div>

    <a class="yb-launcher-scroll" href="#consult" aria-label="상담 신청 영역으로 이동">
      <span>SCROLL</span>
      <i aria-hidden="true"></i>
    </a>
  </section>

  <section class="yb-launcher-consult" id="consult" aria-labelledby="yb-launcher-consult-title">
    <div class="yb-launcher-consult__background" aria-hidden="true"></div>
    <div class="yb-launcher-consult__inner">
      <div class="yb-launcher-consult__intro">
        <p>24H CONSULTATION</p>
        <h2 id="yb-launcher-consult-title">현재 피해 정황을 남겨주세요</h2>
        <span>입금내역, 출금 지연, 추가입금 요구, 연락두절 등 핵심 상황을 남기면 접수 순서에 따라 확인합니다.</span>

        <div class="yb-launcher-consult__quick">
          <a href={site.telLink || 'tel:01021754252'}>
            <small>전화 상담</small>
            <strong>{site.phone || '010-2175-4252'}</strong>
          </a>
          <a href={site.kakaoUrl || 'https://open.kakao.com/o/sEEHGIti'} target="_blank" rel="noopener noreferrer">
            <small>카카오 상담</small>
            <strong>실시간 문의</strong>
          </a>
        </div>
      </div>

      <div class="yb-launcher-consult__form">
        <ConsultForm site={site} caseName={`${site.shortName || '금융사기'} 상담`} />
      </div>
    </div>
  </section>
</main>

<Footer site={site} />

<style>
  .yb-launcher {
    min-height: 100vh;
    background: var(--yb-bg);
    color: var(--yb-text);
  }

  .yb-launcher-hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    isolation: isolate;
    overflow: hidden;
    padding: 72px 22px 94px;
    background:
      radial-gradient(circle at 74% 70%, var(--yb-accent-soft), transparent 34%),
      linear-gradient(135deg, var(--yb-bg-deep) 0%, var(--yb-bg) 40%, var(--yb-bg-mid) 72%, var(--yb-bg-deep) 100%);
  }

  .yb-launcher-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.70), transparent 31%, transparent 69%, rgba(0, 0, 0, 0.58)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.43));
    pointer-events: none;
  }

  .yb-shared-background {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .yb-shared-background__panel {
    position: absolute;
    border: 1px solid rgba(255, 255, 255, 0.035);
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.035), transparent 72%);
  }

  .yb-shared-background__panel--left {
    left: -5%;
    top: 23%;
    width: 37%;
    height: 43%;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.045), transparent 62%),
      var(--yb-surface);
    opacity: 0.82;
  }

  .yb-shared-background__panel--right {
    right: -3%;
    top: 23%;
    width: 60%;
    height: 43%;
    background:
      linear-gradient(145deg, var(--yb-secondary-soft), transparent 68%),
      var(--yb-bg-mid);
    opacity: 0.92;
  }

  .yb-shared-background__panel--bottom {
    left: 30%;
    bottom: -15%;
    width: 42%;
    height: 42%;
    background:
      linear-gradient(180deg, var(--yb-accent-soft), transparent 72%),
      var(--yb-surface);
    opacity: 0.54;
  }

  .yb-shared-background__grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.014) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
    background-size: 82px 82px;
    opacity: 0.38;
  }

  .yb-shared-background__glow {
    position: absolute;
    width: min(72vw, 760px);
    aspect-ratio: 1;
    left: 50%;
    top: 51%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, var(--yb-accent-glow), transparent 66%);
    filter: blur(18px);
    opacity: 0.18;
  }

  .yb-launcher-hero__content {
    position: relative;
    z-index: 2;
    width: min(92vw, 760px);
    margin: 0 auto;
    text-align: center;
    transform: translateY(-2.5vh);
  }

  .yb-launcher-hero__eyebrow {
    margin: 0 0 18px;
    color: var(--yb-muted);
    font-size: clamp(12px, 1.4vw, 14px);
    font-weight: 620;
    line-height: 1.3;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .yb-launcher-hero h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(46px, 7vw, 76px);
    font-weight: 600;
    line-height: 1.06;
    letter-spacing: -0.07em;
    text-wrap: balance;
  }

  .yb-launcher-hero__subtitle {
    width: min(100%, 660px);
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: clamp(15px, 1.75vw, 18px);
    font-weight: 350;
    line-height: 1.75;
    letter-spacing: -0.035em;
    text-wrap: pretty;
  }

  .yb-launcher-search {
    width: min(92vw, 560px);
    min-height: 58px;
    margin: 34px auto 0;
    padding: 6px 7px 6px 22px;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    background: rgba(3, 7, 14, 0.86);
    box-shadow:
      0 20px 56px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .yb-launcher-search:focus-within {
    border-color: var(--yb-accent-2);
    box-shadow:
      0 22px 62px rgba(0, 0, 0, 0.38),
      0 0 0 4px var(--yb-secondary-soft);
  }

  .yb-launcher-search.is-invalid {
    border-color: #ef7078;
    animation: ybSearchShake 240ms ease;
  }

  .yb-launcher-search input {
    flex: 1;
    min-width: 0;
    height: 44px;
    padding: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    caret-color: var(--yb-accent-2);
    font-size: 16px;
    font-weight: 430;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .yb-launcher-search input::placeholder {
    color: rgba(255, 255, 255, 0.54);
    opacity: 1;
  }

  .yb-launcher-search input::-webkit-search-cancel-button {
    filter: invert(1);
    opacity: 0.55;
  }

  .yb-launcher-search button {
    width: 94px;
    height: 46px;
    flex: 0 0 94px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    border: 1px solid var(--yb-accent-2);
    border-radius: 999px;
    background: linear-gradient(135deg, var(--yb-accent), var(--yb-accent-strong));
    color: var(--yb-on-accent);
    box-shadow: 0 12px 26px var(--yb-accent-soft);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: -0.025em;
    transition: transform 160ms ease, filter 160ms ease;
  }

  .yb-launcher-search button svg {
    width: 18px;
    height: 18px;
  }

  .yb-launcher-search button:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .yb-launcher-search button:active {
    transform: scale(0.98);
  }

  .yb-launcher-search button:focus-visible {
    outline: 3px solid var(--yb-accent-2);
    outline-offset: 3px;
  }

  .yb-launcher-hero__guide {
    width: min(90vw, 560px);
    margin: 14px auto 0;
    color: rgba(255, 255, 255, 0.42);
    font-size: 12.5px;
    line-height: 1.65;
    letter-spacing: -0.025em;
  }

  .yb-launcher-scroll {
    position: absolute;
    z-index: 3;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    display: grid;
    justify-items: center;
    gap: 9px;
    color: rgba(255, 255, 255, 0.38);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.22em;
  }

  .yb-launcher-scroll i {
    width: 1px;
    height: 30px;
    background: linear-gradient(180deg, var(--yb-accent-2), transparent);
    animation: ybScrollPulse 1.9s ease-in-out infinite;
  }

  .yb-launcher-consult {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 104px 22px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(circle at 84% 18%, var(--yb-accent-soft), transparent 29%),
      linear-gradient(145deg, var(--yb-bg-deep), var(--yb-bg-mid) 58%, var(--yb-bg-deep));
  }

  .yb-launcher-consult__background {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 82px 82px;
    opacity: 0.38;
  }

  .yb-launcher-consult__inner {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(38px, 6vw, 78px);
    align-items: center;
  }

  .yb-launcher-consult__intro > p {
    margin: 0 0 14px;
    color: var(--yb-accent-2);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.4;
    letter-spacing: 0.18em;
  }

  .yb-launcher-consult__intro h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(34px, 4.8vw, 58px);
    font-weight: 650;
    line-height: 1.16;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .yb-launcher-consult__intro > span {
    display: block;
    max-width: 580px;
    margin-top: 20px;
    color: var(--yb-muted);
    font-size: 17px;
    font-weight: 350;
    line-height: 1.8;
    letter-spacing: -0.035em;
  }

  .yb-launcher-consult__quick {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 30px;
  }

  .yb-launcher-consult__quick a {
    min-height: 78px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    padding: 15px 18px;
    border: 1px solid var(--yb-line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.045);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .yb-launcher-consult__quick a:hover {
    transform: translateY(-2px);
    border-color: var(--yb-accent-2);
    background: var(--yb-secondary-soft);
  }

  .yb-launcher-consult__quick small {
    color: var(--yb-muted);
    font-size: 11px;
  }

  .yb-launcher-consult__quick strong {
    color: #fff;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.035em;
  }

  .yb-launcher-consult__form {
    padding: clamp(22px, 4vw, 36px);
    border: 1px solid var(--yb-line);
    border-radius: 16px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025)),
      rgba(2, 5, 11, 0.70);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.35);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }

  @keyframes ybScrollPulse {
    0%, 100% { transform: scaleY(0.72); opacity: 0.35; transform-origin: top; }
    50% { transform: scaleY(1); opacity: 1; transform-origin: top; }
  }

  @keyframes ybSearchShake {
    0%, 100% { transform: translateX(0); }
    35% { transform: translateX(-5px); }
    70% { transform: translateX(5px); }
  }

  @media (max-width: 820px) {
    .yb-launcher-consult__inner {
      grid-template-columns: 1fr;
      gap: 34px;
    }
  }

  @media (max-width: 580px) {
    .yb-launcher-hero {
      min-height: 100svh;
      padding: 64px 18px 86px;
    }

    .yb-shared-background__panel--left {
      left: -20%;
      width: 52%;
    }

    .yb-shared-background__panel--right {
      right: -22%;
      width: 76%;
    }

    .yb-shared-background__panel--bottom {
      left: 30%;
      width: 55%;
    }

    .yb-launcher-hero__content {
      width: min(92vw, 430px);
      transform: translateY(-2vh);
    }

    .yb-launcher-hero__eyebrow {
      margin-bottom: 16px;
      font-size: 11px;
      letter-spacing: 0.16em;
    }

    .yb-launcher-hero h1 {
      font-size: clamp(40px, 11.8vw, 54px);
      line-height: 1.08;
    }

    .yb-launcher-hero__subtitle {
      margin-top: 20px;
      font-size: 15px;
      line-height: 1.72;
    }

    .yb-launcher-search {
      width: min(92vw, 390px);
      min-height: 52px;
      margin-top: 28px;
      padding: 5px 6px 5px 17px;
    }

    .yb-launcher-search input {
      height: 42px;
      font-size: 16px;
    }

    .yb-launcher-search button {
      width: 76px;
      height: 42px;
      flex-basis: 76px;
    }

    .yb-launcher-search button span {
      display: none;
    }

    .yb-launcher-search button svg {
      width: 19px;
      height: 19px;
    }

    .yb-launcher-hero__guide {
      font-size: 12px;
    }

    .yb-launcher-consult {
      padding: 78px 18px;
    }

    .yb-launcher-consult__intro h2 {
      font-size: clamp(31px, 9vw, 42px);
    }

    .yb-launcher-consult__intro > span {
      font-size: 15px;
      line-height: 1.75;
    }

    .yb-launcher-consult__quick {
      grid-template-columns: 1fr;
    }

    .yb-launcher-consult__quick a {
      min-height: 68px;
    }

    .yb-launcher-consult__form {
      padding: 20px 17px;
      border-radius: 13px;
    }
  }

  @media (max-height: 680px) and (min-width: 581px) {
    .yb-launcher-hero__content {
      transform: translateY(-5vh);
    }

    .yb-launcher-scroll {
      display: none;
    }
  }
</style>

<script is:inline>
  const launcherForm = document.getElementById('ybLauncherSearch');
  const launcherInput = document.getElementById('ybLauncherInput');

  if (launcherForm && launcherInput) {
    launcherInput.addEventListener('input', () => {
      launcherForm.classList.remove('is-invalid');
    });

    launcherForm.addEventListener('submit', (event) => {
      event.preventDefault();

      const keyword = String(launcherInput.value || '')
        .normalize('NFC')
        .trim()
        .replace(/\s+/g, ' ');

      if (!keyword) {
        launcherForm.classList.add('is-invalid');
        launcherInput.focus();
        return;
      }

      // 현재 접속 도메인의 상대경로만 사용합니다.
      window.location.assign(`/scam/${encodeURIComponent(keyword)}`);
    });
  }
</script>
