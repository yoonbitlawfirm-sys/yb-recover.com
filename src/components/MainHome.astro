---
const { site = {} } = Astro.props;

const theme = site?.theme || 'main';
const accent = site?.colors?.accent || '#a61c27';
const gold = site?.colors?.gold || '#c9a45c';
const danger = site?.colors?.accent || '#7f1d1d';
const launcher = site?.launcher || {};
const isRecover = site?.siteKey === 'yb-recover';
---

<style is:global>
  header,
  nav,
  .site-header,
  .yb-header,
  .global-header,
  .main-header,
  .top-header,
  .navbar,
  .gnb,
  .header,
  .header-wrap,
  .nav-wrap,
  .navigation,
  .desktop-nav,
  .mobile-nav,
  .top-floating,
  .top-fixed,
  .fixed-top,
  .floating-top,
  .reservation-bar,
  .consult-reserve,
  .reserve-button,
  .bottom-floating,
  .floating-cta,
  .bottom-cta,
  .sticky-cta,
  .fixed-cta,
  .mobile-cta,
  .consult-floating,
  .floating-consult,
  .quick-consult,
  .quick-cta,
  .cta-fixed,
  .fixed-bottom,
  .bottom-bar,
  .floating-bar,
  .contact-floating,
  .floating-bottom,
  .bottom-consult,
  .consult-bar,
  .sticky-bottom,
  .floating-call,
  .call-floating,
  .fixed-consult-bar,
  .floating-actions,
  .fixed-actions,
  .fixed-contact,
  .floating-contact,
  .bottom-buttons,
  .bottom-button-wrap,
  .bottom-action-bar,
  .bottom-fixed-cta,
  .mobile-bottom-fixed,
  .mobile-bottom-cta,
  .mobile-fixed-bottom,
  .quick-buttons,
  .quick-action-buttons,
  .call-kakao-floating,
  .call-kakao-bar,
  .contact-actions,
  .contact-action-bar,
  .tel-kakao-bar,
  .phone-kakao-bar {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  footer:not(.yb-launch-footer),
  .site-footer,
  .global-footer,
  .main-footer,
  .footer,
  .footer-wrap,
  .copyright,
  .page-footer {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  html,
  body {
    margin: 0 !important;
    padding: 0 !important;
    overflow-x: hidden;
    background: var(--site-bg, #02050b);
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
  }
</style>

<section
  class={`launch-base launch-base-${theme}`}
  style={`--yb-accent:${accent};--yb-gold:${gold};--yb-danger:${danger};--site-bg:${site?.colors?.bg || "#02050b"};--site-surface:${site?.colors?.surface || "#07101d"};--site-text:${site?.colors?.text || "#fff"};`}
>
  <div class="launch-bg" aria-hidden="true">
    <div class="launch-scene scene-a"></div>
    <div class="launch-scene scene-b"></div>
    <div class="launch-scene scene-c"></div>
    <div class="launch-gridline"></div>
  </div>

  <div class="launch-brand">
    <p class="launch-kicker">{launcher.eyebrow || site.shortName}</p>

    <h1>{launcher.headline || site.siteName}</h1>

    <p class="launch-subtitle">
      {launcher.subtitle || site.description}
    </p>

    <form
      class="launch-searchbox"
      id="launchSearch"
      action="/scam/출금거부"
      method="get"
      aria-label="피해 정황 검색"
    >
      <input
        id="launchSearchInput"
        type="search"
        placeholder={launcher.placeholder || "업체명 또는 키워드를 입력하세요"}
        autocomplete="off"
      />

      <button type="submit" aria-label="검색">
        <svg
          viewBox="0 0 24 24"
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
      </button>
    </form>

    <p class="launch-guide">
      {launcher.guide || "입력한 키워드 안내 페이지로 이동합니다."}
    </p>
  </div>
</section>

<footer class="yb-launch-footer">
  <div class="yb-launch-footer-inner">
    <p class="yb-launch-footer-title">
      <strong>{site.siteName}</strong>
      {isRecover && <span>ㅣ금융사기 피해회복센터</span>}
    </p>

    <div class="yb-launch-footer-info">
      <p>상담 연결 : {site.phone} · {site.email}</p>
      <p>운영 및 상담 연계 : {site.operatorName}</p>
      {isRecover && <p>광고책임변호사 : {site.responsibleAttorney} · 사업자등록번호 : {site.businessNumber}</p>}
      {isRecover && <p>주소 : {site.address}</p>}
    </div>

    <p class="yb-launch-footer-copy">
      © 2026 {site.siteName}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .launch-base {
    position: relative;
    min-height: 100svh;
    height: 100svh;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    overflow: hidden;
  }

  .launch-brand {
    position: relative;
    z-index: 5;
    width: min(90vw, 720px);
    margin: 0 auto;
    text-align: center;
    transform: translateY(-2vh);
  }

  .launch-kicker {
    margin: 0 0 18px;
    font-size: clamp(12px, 1.45vw, 14px);
    line-height: 1;
    letter-spacing: 0.28em;
    color: rgba(255, 255, 255, 0.56);
    font-weight: 400;
  }

  .launch-brand h1 {
    margin: 0;
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
    font-size: clamp(42px, 7vw, 74px);
    line-height: 1.08;
    letter-spacing: -0.065em;
    color: rgba(255, 255, 255, 0.96);
    font-weight: 500;
    text-shadow: none;
  }

  .launch-subtitle {
    width: min(92vw, 620px);
    margin: 24px auto 0;
    font-size: clamp(15px, 1.7vw, 18px);
    line-height: 1.75;
    letter-spacing: -0.035em;
    word-break: keep-all;
    color: rgba(255, 255, 255, 0.68);
    font-weight: 300;
  }

  .launch-searchbox {
    width: min(86vw, 500px) !important;
    height: 54px !important;
    min-height: 54px !important;
    margin: 34px auto 0 !important;
    padding: 0 7px 0 22px !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    border-radius: 999px !important;
    background: rgba(4, 8, 16, 0.68) !important;
    border: 1px solid rgba(255, 255, 255, 0.13) !important;
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.045) !important;
    backdrop-filter: blur(16px);
  }

  .launch-searchbox input {
    flex: 1;
    width: 100%;
    height: 100% !important;
    border: 0 !important;
    outline: 0 !important;
    background: transparent !important;
    color: rgba(255, 255, 255, 0.9) !important;
    font-size: 14.5px !important;
    letter-spacing: -0.025em;
    font-weight: 300 !important;
  }

  .launch-searchbox input::placeholder {
    color: rgba(255, 255, 255, 0.36) !important;
    font-weight: 300;
  }

  .launch-searchbox button {
    width: 42px !important;
    height: 42px !important;
    min-width: 42px !important;
    padding: 0 !important;
    border-radius: 50% !important;
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
    background: rgba(166, 28, 39, 0.92) !important;
    color: #fff !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer;
    box-shadow: 0 8px 22px rgba(139, 18, 28, 0.24);
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease;
  }

  .launch-searchbox button:hover {
    transform: translateY(-1px);
    background: rgba(185, 34, 46, 0.96) !important;
    box-shadow: 0 12px 28px rgba(139, 18, 28, 0.32);
  }

  .launch-guide {
    width: min(86vw, 480px);
    margin: 15px auto 0;
    font-size: 13px;
    line-height: 1.65;
    letter-spacing: -0.035em;
    word-break: keep-all;
    color: rgba(255, 255, 255, 0.42);
    font-weight: 300;
  }

  .yb-launch-footer {
    margin: 0;
    padding: 42px 22px 48px;
    background: #02050b;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.58);
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      "Noto Sans KR",
      sans-serif;
  }

  .yb-launch-footer-inner {
    width: min(100%, 920px);
    margin: 0 auto;
  }

  .yb-launch-footer p {
    margin: 0;
    padding: 0;
    word-break: keep-all;
  }

  .yb-launch-footer-title {
    margin-bottom: 18px !important;
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.04em;
  }

  .yb-launch-footer-title strong {
    color: #ffffff;
    font-weight: 700;
  }

  .yb-launch-footer-title span {
    color: rgba(255, 255, 255, 0.66);
    font-weight: 300;
  }

  .yb-launch-footer-info {
    display: grid;
    gap: 5px;
    margin-bottom: 22px;
  }

  .yb-launch-footer-info p {
    font-size: 14px;
    line-height: 1.65;
    letter-spacing: -0.035em;
    color: rgba(255, 255, 255, 0.62);
    font-weight: 300;
  }

  .yb-launch-footer-copy {
    font-size: 13px;
    line-height: 1.6;
    letter-spacing: -0.035em;
    color: rgba(255, 255, 255, 0.42);
    font-weight: 300;
  }

  @media (max-width: 640px) {
    .launch-brand {
      width: min(88vw, 420px);
      transform: translateY(-3vh);
    }

    .launch-kicker {
      margin-bottom: 16px;
      font-size: 12px;
      letter-spacing: 0.22em;
    }

    .launch-brand h1 {
      font-size: clamp(40px, 11.5vw, 56px);
      line-height: 1.08;
      font-weight: 500;
      letter-spacing: -0.07em;
    }

    .launch-subtitle {
      margin-top: 22px;
      font-size: 15px;
      line-height: 1.68;
      color: rgba(255, 255, 255, 0.66);
    }

    .launch-searchbox {
      width: min(88vw, 360px) !important;
      height: 50px !important;
      min-height: 50px !important;
      margin-top: 30px !important;
      padding-left: 18px !important;
      padding-right: 6px !important;
    }

    .launch-searchbox input {
      font-size: 14px !important;
    }

    .launch-searchbox button {
      width: 38px !important;
      height: 38px !important;
      min-width: 38px !important;
    }

    .launch-guide {
      width: min(84vw, 340px);
      margin-top: 14px;
      font-size: 12.5px;
      line-height: 1.6;
    }

    .yb-launch-footer {
      padding: 36px 18px 42px;
    }

    .yb-launch-footer-title {
      margin-bottom: 16px !important;
      font-size: 15px;
    }

    .yb-launch-footer-info {
      gap: 4px;
      margin-bottom: 20px;
    }

    .yb-launch-footer-info p {
      font-size: 13px;
      line-height: 1.7;
    }

    .yb-launch-footer-copy {
      font-size: 12px;
    }
  }

  @media (max-height: 680px) {
    .launch-brand {
      transform: translateY(-6vh);
    }
  }

  .launch-base-response .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(40,120,215,.24), transparent 28%), linear-gradient(145deg,#07111f,#0c1f38 56%,#030914); }
  .launch-base-alert .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(209,75,49,.24), transparent 28%), linear-gradient(145deg,#130907,#2a100b 56%,#090302); }
  .launch-base-check { color:#13252d; }
  .launch-base-check .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(20,138,138,.18), transparent 30%), linear-gradient(145deg,#edf7f8,#dfeef1 58%,#f8fbfc); }
  .launch-base-check .launch-brand h1,.launch-base-check .launch-subtitle { color:#13252d; text-shadow:none; }
  .launch-base-check .launch-kicker,.launch-base-check .launch-guide { color:rgba(19,37,45,.58); }
  .launch-base-check .launch-searchbox { background:rgba(255,255,255,.78)!important;border-color:rgba(19,37,45,.16)!important; }
  .launch-base-check .launch-searchbox input { color:#13252d!important; }
  .launch-base-case .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(168,121,56,.24), transparent 28%), linear-gradient(145deg,#15110d,#2c2115 56%,#080604); }
  .launch-base-safe .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(39,168,121,.22), transparent 28%), linear-gradient(145deg,#061410,#0d2a20 56%,#020907); }
  .launch-base-help .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(102,94,232,.24), transparent 28%), linear-gradient(145deg,#0b0d18,#202044 56%,#05060c); }
  .launch-base-watch .launch-bg { background: radial-gradient(circle at 50% 42%, rgba(20,169,199,.24), transparent 28%), linear-gradient(145deg,#04121b,#0a3040 56%,#02080c); }
</style>

<script is:inline>
  const form = document.getElementById('launchSearch');
  const input = document.getElementById('launchSearchInput');

  if (form && input) {
    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const keyword = (input.value || '').replace(/\s+/g, '').trim() || '출금거부';

      location.href = `/scam/${encodeURIComponent(keyword)}`;
    });
  }
</script>

<style>
  /* 8개 도메인 발사대 시각 분리 강화 */

  .launch-base-response .launch-bg {
    background:
      linear-gradient(120deg,rgba(0,102,255,.18) 0 1px,transparent 1px 76px),
      radial-gradient(circle at 72% 28%,rgba(125,211,252,.34),transparent 20%),
      linear-gradient(145deg,#021126,#063a78 58%,#020a17);
  }
  .launch-base-response .launch-scene-a { border:1px solid rgba(125,211,252,.28); transform:rotate(12deg) scale(1.2); }
  .launch-base-response .launch-searchbox button { background:linear-gradient(135deg,#0066ff,#003ea8)!important; }

  .launch-base-alert .launch-bg {
    background:
      repeating-linear-gradient(135deg,rgba(255,176,0,.08) 0 12px,transparent 12px 28px),
      radial-gradient(circle at 50% 38%,rgba(255,45,0,.38),transparent 27%),
      linear-gradient(145deg,#200100,#5b0a02 58%,#120000);
  }
  .launch-base-alert .launch-kicker { color:#ffb000; font-weight:700; }
  .launch-base-alert .launch-searchbox button { background:linear-gradient(135deg,#ff2d00,#b51d00)!important; }

  .launch-base-check { color:#102a2a; }
  .launch-base-check .launch-bg {
    background:
      radial-gradient(circle at 20% 18%,rgba(0,168,150,.18),transparent 24%),
      radial-gradient(circle at 82% 75%,rgba(0,109,119,.12),transparent 24%),
      linear-gradient(145deg,#f7fffc,#ddfaf2 58%,#ffffff);
  }
  .launch-base-check .launch-gridline { opacity:.16; filter:invert(1); }
  .launch-base-check .launch-brand h1 { color:#082f2b; }
  .launch-base-check .launch-subtitle { color:rgba(16,42,42,.72); }
  .launch-base-check .launch-searchbox button { background:linear-gradient(135deg,#00a896,#006d77)!important; }

  .launch-base-case .launch-bg {
    background:
      linear-gradient(90deg,rgba(244,180,0,.10) 1px,transparent 1px),
      linear-gradient(rgba(244,180,0,.08) 1px,transparent 1px),
      radial-gradient(circle at 52% 36%,rgba(244,180,0,.31),transparent 27%),
      linear-gradient(145deg,#171100,#4e3b00 58%,#0b0800);
    background-size:auto,64px 64px,64px 64px,auto,auto;
  }
  .launch-base-case .launch-brand h1 { color:#fff4b0; }
  .launch-base-case .launch-searchbox button { background:linear-gradient(135deg,#f4b400,#b77c00)!important;color:#241800!important; }

  .launch-base-safe .launch-bg {
    background:
      radial-gradient(ellipse at 50% 120%,rgba(21,196,107,.28),transparent 42%),
      repeating-radial-gradient(circle at 50% 50%,rgba(158,240,184,.07) 0 2px,transparent 2px 42px),
      linear-gradient(145deg,#03140b,#07572c 58%,#010904);
  }
  .launch-base-safe .launch-searchbox { border-radius:18px!important; }
  .launch-base-safe .launch-searchbox button { background:linear-gradient(135deg,#15c46b,#08733b)!important; }

  .launch-base-help .launch-bg {
    background:
      radial-gradient(circle at 25% 22%,rgba(255,112,215,.26),transparent 22%),
      radial-gradient(circle at 76% 76%,rgba(181,23,255,.34),transparent 28%),
      linear-gradient(145deg,#14001e,#4d006b 58%,#09000e);
  }
  .launch-base-help .launch-scene-b { border-radius:50%; filter:blur(8px); }
  .launch-base-help .launch-searchbox button { background:linear-gradient(135deg,#b517ff,#ff3eb5)!important; }

  .launch-base-watch .launch-bg {
    background:
      linear-gradient(90deg,transparent 49.7%,rgba(0,212,255,.22) 50%,transparent 50.3%),
      linear-gradient(transparent 49.7%,rgba(0,212,255,.14) 50%,transparent 50.3%),
      radial-gradient(circle at 50% 42%,rgba(0,212,255,.28),transparent 25%),
      linear-gradient(145deg,#001118,#00485a 58%,#00080b);
    background-size:120px 120px,120px 120px,auto,auto;
  }
  .launch-base-watch .launch-brand h1 { text-transform:uppercase; letter-spacing:-.045em; }
  .launch-base-watch .launch-searchbox button { background:linear-gradient(135deg,#00d4ff,#007a93)!important;color:#00181f!important; }
</style>
