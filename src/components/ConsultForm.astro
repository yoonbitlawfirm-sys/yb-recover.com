---
const { site, caseName = '금융사기' } = Astro.props;
---
<form class="yb-form" data-consult-form>
  <input type="hidden" name="caseName" value={caseName} />
  <input type="text" name="name" placeholder="이름" required />
  <input type="tel" name="phone" placeholder="연락처" required maxlength="13" />
  <input type="text" name="amount" placeholder="피해금액 예: 30,000,000" inputmode="numeric" />
  <textarea name="message" rows="4" placeholder="현재 상황을 간단히 적어주세요"></textarea>
  <button type="submit">피해 정황 상담 신청</button>
  <p style="margin:0;color:var(--yb-muted);font-size:13px;line-height:1.6;">접수 후 담당자가 순차적으로 확인합니다. 긴급한 경우 <a href={site.telLink} style="color:var(--yb-accent2);">{site.phone}</a>로 전화하세요.</p>
</form>
<script>
  document.querySelectorAll('[data-consult-form]').forEach((form) => {
    const phone = form.querySelector('input[name="phone"]');
    const amount = form.querySelector('input[name="amount"]');
    phone?.addEventListener('input', () => {
      let v = phone.value.replace(/[^0-9]/g, '').slice(0, 11);
      phone.value = v.length <= 3 ? v : v.length <= 7 ? `${v.slice(0,3)}-${v.slice(3)}` : `${v.slice(0,3)}-${v.slice(3,7)}-${v.slice(7)}`;
    });
    amount?.addEventListener('input', () => {
      const v = amount.value.replace(/[^0-9]/g, '');
      amount.value = v ? Number(v).toLocaleString() : '';
    });
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector('button');
      const original = button.textContent;
      button.textContent = '접수 중...';
      button.disabled = true;
      try {
        const data = Object.fromEntries(new FormData(form).entries());
        data.phone = String(data.phone || '').replace(/[^0-9]/g, '');
        data.amount = String(data.amount || '').replace(/[^0-9]/g, '');
        const res = await fetch('/api/send-mail', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(data)
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.success) throw new Error(json.error || 'failed');
        form.innerHTML = '<div style="padding:34px;text-align:center;border:1px solid rgba(255,255,255,.12);color:#fff;line-height:1.8;"><strong style="font-size:22px;">상담 접수가 완료되었습니다.</strong><br/>담당자가 확인 후 연락드리겠습니다.</div>';
      } catch (e) {
        alert('접수 중 오류가 발생했습니다. 전화상담으로 문의해주세요.');
        button.textContent = original;
        button.disabled = false;
      }
    });
  });
</script>
