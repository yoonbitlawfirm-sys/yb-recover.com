---
const { site = {}, caseName = '금융사기' } = Astro.props;
const formId = `yb-consult-${Math.random().toString(36).slice(2, 9)}`;
---

<form class="yb-consult-form" id={formId} data-consult-form novalidate>
  <input type="hidden" name="caseName" value={caseName} />
  <input type="hidden" name="siteName" value={site.siteName || '법무법인 윤빛'} />
  <input type="hidden" name="sourcePath" value={Astro.url.pathname} />

  <label class="yb-consult-form__field">
    <span>이름 <em>필수</em></span>
    <input type="text" name="name" placeholder="성함을 입력하세요" required maxlength="30" autocomplete="name" />
  </label>

  <label class="yb-consult-form__field">
    <span>연락처 <em>필수</em></span>
    <input type="tel" name="phone" placeholder="010-0000-0000" required maxlength="13" inputmode="tel" autocomplete="tel" />
  </label>

  <label class="yb-consult-form__field">
    <span>피해금액 <small>선택</small></span>
    <input type="text" name="amount" placeholder="예: 30,000,000" inputmode="numeric" maxlength="18" />
  </label>

  <label class="yb-consult-form__field">
    <span>현재 상황 <small>선택</small></span>
    <textarea name="message" rows="5" placeholder="출금 지연, 추가 입금 요구, 연락두절 등 현재 상황을 적어주세요" maxlength="2000"></textarea>
  </label>

  <div class="yb-consult-form__privacy-summary" aria-label="개인정보 수집 이용 안내">
    <p><strong>수집 항목</strong><span>이름, 연락처, 상담 사건명(필수) / 피해금액, 상담 내용(선택)</span></p>
    <p><strong>이용 목적</strong><span>상담 접수, 사실관계 확인 및 상담 연락</span></p>
    <p><strong>보유 기간</strong><span>상담 목적 달성 후 지체 없이 파기. 다만 법령 준수·분쟁 대응이 필요한 경우 해당 기간까지 보관</span></p>
    <p><strong>동의 거부</strong><span>동의를 거부할 수 있으나 웹 상담 접수가 제한됩니다. 전화·카카오 상담은 이용할 수 있습니다.</span></p>
  </div>

  <label class="yb-consult-form__privacy">
    <input type="checkbox" name="privacyConsent" value="true" required />
    <span>
      <b>[필수]</b> 위 개인정보 수집·이용 안내를 확인했으며 이에 동의합니다.
      <a href="/privacy" target="_blank" rel="noopener noreferrer">전체 방침 보기</a>
    </span>
  </label>

  <div class="yb-consult-form__honeypot" aria-hidden="true">
    <label>웹사이트<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
  </div>

  <button type="submit" class="yb-consult-form__submit">피해 정황 상담 신청</button>

  <p class="yb-consult-form__help">
    접수 순서에 따라 담당자가 연락드립니다. 긴급한 경우
    <a href={site.telLink || 'tel:01021754252'}>{site.phone || '010-2175-4252'}</a>로 전화해 주세요.
  </p>

  <p class="yb-consult-form__status" role="status" aria-live="polite" hidden></p>
</form>

<style>
  .yb-consult-form {
    display: grid;
    gap: 14px;
  }

  .yb-consult-form__field {
    display: grid;
    gap: 8px;
  }

  .yb-consult-form__field > span {
    display: flex;
    align-items: center;
    gap: 7px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 13px;
    font-weight: 650;
    letter-spacing: -0.025em;
  }

  .yb-consult-form__field em,
  .yb-consult-form__field small {
    font-style: normal;
    font-size: 10px;
    font-weight: 700;
  }

  .yb-consult-form__field em {
    color: var(--yb-accent-2);
  }

  .yb-consult-form__field small {
    color: rgba(255, 255, 255, 0.43);
  }

  .yb-consult-form input[type="text"],
  .yb-consult-form input[type="tel"],
  .yb-consult-form textarea {
    width: 100%;
    min-height: 52px;
    margin: 0;
    padding: 14px 15px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    outline: none;
    background: rgba(255, 255, 255, 0.045);
    color: #fff;
    font-size: 15px;
    line-height: 1.5;
    letter-spacing: -0.025em;
    transition: border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
  }

  .yb-consult-form textarea {
    min-height: 126px;
    resize: vertical;
  }

  .yb-consult-form input::placeholder,
  .yb-consult-form textarea::placeholder {
    color: rgba(255, 255, 255, 0.36);
    opacity: 1;
  }

  .yb-consult-form input:focus,
  .yb-consult-form textarea:focus {
    border-color: var(--yb-accent-2);
    background: rgba(255, 255, 255, 0.065);
    box-shadow: 0 0 0 3px var(--yb-secondary-soft);
  }

  .yb-consult-form__privacy-summary {
    display: grid;
    gap: 6px;
    padding: 14px 15px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.028);
  }

  .yb-consult-form__privacy-summary p {
    display: grid;
    grid-template-columns: 74px minmax(0, 1fr);
    gap: 8px;
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 10.5px;
    line-height: 1.55;
    letter-spacing: -0.02em;
  }

  .yb-consult-form__privacy-summary strong {
    color: rgba(255, 255, 255, 0.78);
    font-weight: 720;
  }

  .yb-consult-form__privacy {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    padding: 3px 1px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 12px;
    line-height: 1.65;
    letter-spacing: -0.02em;
    cursor: pointer;
  }

  .yb-consult-form__privacy input {
    width: 17px;
    height: 17px;
    flex: 0 0 17px;
    margin: 2px 0 0;
    accent-color: var(--yb-accent);
  }

  .yb-consult-form__privacy b {
    color: var(--yb-accent-2);
  }

  .yb-consult-form__privacy a {
    margin-left: 4px;
    color: rgba(255, 255, 255, 0.88);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .yb-consult-form__submit {
    min-height: 56px;
    border: 1px solid transparent;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--yb-accent), var(--yb-accent-strong));
    color: var(--yb-on-accent);
    box-shadow: 0 16px 34px var(--yb-accent-soft);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.03em;
    transition: transform 160ms ease, filter 160ms ease, box-shadow 160ms ease;
  }

  .yb-consult-form__submit:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    box-shadow: 0 20px 42px var(--yb-accent-glow);
  }

  .yb-consult-form__submit:active {
    transform: translateY(0) scale(0.99);
  }

  .yb-consult-form__submit:focus-visible {
    outline: 3px solid var(--yb-accent-2);
    outline-offset: 3px;
  }

  .yb-consult-form__submit:disabled {
    cursor: wait;
    opacity: 0.68;
  }

  .yb-consult-form__help,
  .yb-consult-form__status {
    margin: 0;
    color: var(--yb-muted);
    font-size: 12px;
    line-height: 1.65;
    letter-spacing: -0.02em;
  }

  .yb-consult-form__help a {
    color: var(--yb-accent-2);
    font-weight: 700;
  }

  .yb-consult-form__status {
    padding: 15px;
    border: 1px solid var(--yb-line);
    border-radius: 10px;
    background: var(--yb-secondary-soft);
    color: rgba(255, 255, 255, 0.86);
  }

  .yb-consult-form__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .yb-consult-form.is-invalid .yb-consult-form__privacy {
    color: #ffb6bb;
  }

  @media (max-width: 560px) {
    .yb-consult-form {
      gap: 12px;
    }

    .yb-consult-form input[type="text"],
    .yb-consult-form input[type="tel"],
    .yb-consult-form textarea {
      font-size: 16px;
    }

    .yb-consult-form__privacy-summary p {
      grid-template-columns: 66px minmax(0, 1fr);
      font-size: 10px;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-consult-form]').forEach((form) => {
    if (form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const phone = form.querySelector('input[name="phone"]');
    const amount = form.querySelector('input[name="amount"]');
    const consent = form.querySelector('input[name="privacyConsent"]');
    const button = form.querySelector('button[type="submit"]');
    const status = form.querySelector('[role="status"]');

    phone?.addEventListener('input', () => {
      const digits = phone.value.replace(/[^0-9]/g, '').slice(0, 11);
      phone.value = digits.length <= 3
        ? digits
        : digits.length <= 7
          ? `${digits.slice(0, 3)}-${digits.slice(3)}`
          : `${digits.slice(0, 3)}-${digits.slice(3, 7)}-${digits.slice(7)}`;
    });

    amount?.addEventListener('input', () => {
      const digits = amount.value.replace(/[^0-9]/g, '').slice(0, 15);
      amount.value = digits ? Number(digits).toLocaleString('ko-KR') : '';
    });

    consent?.addEventListener('change', () => {
      form.classList.remove('is-invalid');
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        if (consent && !consent.checked) form.classList.add('is-invalid');
        return;
      }

      const originalText = button?.textContent || '피해 정황 상담 신청';
      if (button) {
        button.textContent = '접수 중...';
        button.disabled = true;
      }
      if (status) status.hidden = true;

      try {
        const data = Object.fromEntries(new FormData(form).entries());
        data.phone = String(data.phone || '').replace(/[^0-9]/g, '');
        data.amount = String(data.amount || '').replace(/[^0-9]/g, '');
        data.privacyConsent = consent?.checked === true;

        const response = await fetch('/api/send-mail', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.success) {
          throw new Error(result.error || '상담 접수에 실패했습니다.');
        }

        form.querySelectorAll('input:not([type="hidden"]), textarea').forEach((field) => {
          if (field.type === 'checkbox') field.checked = false;
          else field.value = '';
        });

        if (status) {
          status.textContent = '상담 접수가 완료되었습니다. 담당자가 확인 후 연락드리겠습니다.';
          status.hidden = false;
        }
      } catch (error) {
        if (status) {
          status.textContent = error instanceof Error
            ? error.message
            : '접수 중 오류가 발생했습니다. 전화상담으로 문의해 주세요.';
          status.hidden = false;
        } else {
          alert('접수 중 오류가 발생했습니다. 전화상담으로 문의해 주세요.');
        }
      } finally {
        if (button) {
          button.textContent = originalText;
          button.disabled = false;
        }
      }
    });
  });
</script>
